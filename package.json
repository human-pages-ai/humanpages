{
  "name": "humans-marketplace",
  "version": "1.0.0",
  "description": "AI-to-Human marketplace - Yellow Pages for AI agents to find humans",
  "private": true,
  "scripts": {
    "setup": "./setup.sh",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:infisical": "concurrently \"cd backend && infisical run -- npm run dev\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:mcp": "cd mcp-server && npm run dev",
    "test": "cd backend && npm test",
    "test:watch": "cd backend && npm run test:watch",
    "test:e2e": "npx playwright test --config e2e/playwright.config.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "concurrently": "^8.2.2",
    "husky": "^9.1.7",
    "prisma": "^7.3.0",
    "viem": "^2.45.2"
  },
  "dependencies": {
    "@prisma/client": "^7.3.0",
    "playwright": "^1.58.2"
  }
}
