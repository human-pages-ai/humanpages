# Human Pages API
API_URL=https://humanpages.ai

# Agent credentials (leave blank to auto-register on first run)
AGENT_API_KEY=

# Agent registration info (used only if AGENT_API_KEY is blank)
AGENT_NAME=Errand Bot
AGENT_DESCRIPTION=Hires nearby humans for physical-world tasks that AI cannot do alone
AGENT_CONTACT_EMAIL=bot@example.com

# Webhook server (optional — the bot works without webhooks by polling the API)
# WEBHOOK_PORT=4000
# WEBHOOK_HOST=0.0.0.0
# WEBHOOK_URL=https://your-public-url.com
# WEBHOOK_SECRET=change-me-to-a-random-string-at-least-16-chars

# LLM — enables smart, context-aware replies (optional)
# Without these, the bot uses simple keyword matching.
# Priority: OLLAMA_URL > ANTHROPIC_API_KEY > keyword fallback
#
# Option A: Local model (Ollama, LM Studio, or any OpenAI-compatible endpoint)
# OLLAMA_URL=http://localhost:11434
# LLM_MODEL=llama3
#
# Option B: Claude API
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-sonnet-4-5-20250929
#
# Custom system prompt (optional — a sensible default is built in)
# LLM_SYSTEM_PROMPT=

# Errand parameters
ERRAND_DESCRIPTION=Pick up a package from the FedEx at 123 Main St and deliver it to 456 Oak Ave (about 2 miles). Package is pre-paid, just show the pickup code: FX-8823.
JOB_PRICE_USDC=25
