# Human Pages API
API_URL=http://localhost:3000

# Agent credentials (leave blank to auto-register on first run)
AGENT_API_KEY=

# Agent registration info (used only if AGENT_API_KEY is blank)
AGENT_NAME=Errand Bot
AGENT_DESCRIPTION=Hires nearby humans for physical-world tasks that AI cannot do alone
AGENT_CONTACT_EMAIL=bot@example.com

# Webhook server
WEBHOOK_PORT=4000
WEBHOOK_HOST=0.0.0.0

# The public URL where Human Pages can reach this bot's webhook endpoint.
# For local dev with the platform also running locally, use http://host.docker.internal:4000
# or a tunnel like ngrok (e.g. https://abc123.ngrok.io)
WEBHOOK_URL=http://localhost:4000

# Shared secret for verifying webhook signatures (16-256 chars)
WEBHOOK_SECRET=change-me-to-a-random-string-at-least-16-chars

# Errand parameters
# Coordinates for the errand location (default: downtown Los Angeles)
ERRAND_LAT=34.0522
ERRAND_LNG=-118.2437
ERRAND_RADIUS_KM=25
ERRAND_DESCRIPTION=Pick up a package from the FedEx at 123 Main St and deliver it to 456 Oak Ave (about 2 miles). Package is pre-paid, just show the pickup code: FX-8823.
JOB_PRICE_USDC=15
