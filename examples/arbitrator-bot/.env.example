# Human Pages API
HP_API_URL=https://humanpages.ai/api
HP_API_KEY=           # from `npm run register`
HP_AGENT_ID=          # from `npm run register`

# Arbitrator wallet — NEVER commit this file with a real key
ARBITRATOR_PRIVATE_KEY=0x...

# Escrow contract (Base Sepolia)
ESCROW_CONTRACT=0x...
CHAIN_ID=84532
RPC_URL=https://sepolia.base.org

# Webhook security (REQUIRED — server won't start without it)
WEBHOOK_SECRET=          # shared secret for HMAC-SHA256 signature verification

# Server
PORT=3100
