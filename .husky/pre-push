#!/bin/sh

echo "=== Pre-push checks ==="

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

if [ "$NODE_ENV" = "production" ]; then
  echo "ERROR: NODE_ENV=production. Refusing to run E2E tests against production."
  exit 1
fi

# ------------------------------------------------------------------
# Cleanup trap — kill dev servers on exit/ctrl+c if we started them
# ------------------------------------------------------------------
STARTED_SERVERS=0
DEV_PID=""
FINAL_EXIT=0

stop_servers() {
  if [ "$STARTED_SERVERS" = "1" ] && [ -n "$DEV_PID" ]; then
    echo "  Stopping dev servers..."
    pkill -P "$DEV_PID" 2>/dev/null
    kill "$DEV_PID" 2>/dev/null
    wait "$DEV_PID" 2>/dev/null
  fi
}
trap 'FINAL_EXIT=$?; stop_servers; exit $FINAL_EXIT' INT TERM
trap 'FINAL_EXIT=$?; stop_servers; exit $FINAL_EXIT' EXIT

# ------------------------------------------------------------------
# Phase 1: Start dev servers (if needed) AND run type checks + unit
#           tests in parallel. Server startup overlaps with checks.
# ------------------------------------------------------------------

# Start servers early so they boot while checks run
if curl -sf http://localhost:3001/health >/dev/null 2>&1 && curl -sf http://localhost:3000 >/dev/null 2>&1; then
  echo "  Dev servers already running"
else
  echo "  Starting dev servers in background..."
  STARTED_SERVERS=1
  # Kill stale processes on our ports
  lsof -ti :3000 -sTCP:LISTEN 2>/dev/null | xargs kill 2>/dev/null
  lsof -ti :3001 -sTCP:LISTEN 2>/dev/null | xargs kill 2>/dev/null
  sleep 1
  npm run dev >/tmp/human-pages-e2e-servers.log 2>&1 &
  DEV_PID=$!
fi

echo "[1/2] Type checks + unit tests (parallel)"
npx concurrently --kill-others-on-fail \
  -n "tsc:be,tsc:fe,test" \
  "cd backend && npx tsc --noEmit" \
  "cd frontend && npx tsc --noEmit" \
  "cd backend && npm test"

if [ $? -ne 0 ]; then
  echo "  Type checks or unit tests failed"
  exit 1
fi

# ------------------------------------------------------------------
# Phase 2: Wait for servers (should already be up by now), run E2E
# ------------------------------------------------------------------
echo "[2/2] E2E tests"

wait_for_server() {
  local url="$1" label="$2" i=0
  while [ $i -lt 60 ]; do
    curl -sf "$url" >/dev/null 2>&1 && return 0
    i=$((i + 1))
    sleep 1
  done
  echo "  ERROR: $label not ready after 60s"
  return 1
}

if ! wait_for_server "http://localhost:3001/health" "Backend (:3001)"; then
  tail -20 /tmp/human-pages-e2e-servers.log 2>/dev/null
  exit 1
fi

if ! wait_for_server "http://localhost:3000" "Frontend (:3000)"; then
  tail -20 /tmp/human-pages-e2e-servers.log 2>/dev/null
  exit 1
fi

npx playwright test --config e2e/playwright.config.ts
if [ $? -ne 0 ]; then
  echo "  E2E tests failed"
  exit 1
fi

echo "=== All checks passed ==="
