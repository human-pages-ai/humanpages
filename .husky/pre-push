#!/bin/sh

PUSH_START=$(date +%s)
echo "=== Pre-push checks ==="

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# ------------------------------------------------------------------
# Error log — all failures written here for easy debugging
# ------------------------------------------------------------------
ERROR_LOG="$REPO_ROOT/.pre-push-errors.log"
STAGE_LOG="$REPO_ROOT/.pre-push-stage.log"
> "$ERROR_LOG"  # truncate

fail() {
  STAGE="$1"
  shift

  # Write structured error to log file (BEFORE printing, so it's always there)
  {
    echo "STAGE: $STAGE"
    echo "TIME: $(date '+%Y-%m-%d %H:%M:%S')"
    echo "BRANCH: $(git branch --show-current)"
    echo "COMMIT: $(git log --oneline -1)"
    echo ""
    echo "ERROR:"
    for line in "$@"; do
      echo "  $line"
    done
    echo ""
    echo "--- DETAILED OUTPUT ---"
    cat $STAGE_LOG 2>/dev/null
  } > "$ERROR_LOG"

  # Build the error message
  ERROR_MSG=""
  ERROR_MSG="${ERROR_MSG}
═══════════════════════════════════════════════════════════
  PRE-PUSH FAILED at stage: $STAGE
═══════════════════════════════════════════════════════════
"
  for line in "$@"; do
    ERROR_MSG="${ERROR_MSG}  ${line}
"
  done
  ERROR_MSG="${ERROR_MSG}
  Full error log: cat $ERROR_LOG
═══════════════════════════════════════════════════════════"

  # Print to BOTH stdout and stderr so it's visible regardless of how git captures output
  echo "$ERROR_MSG"
  echo "$ERROR_MSG" >&2

  exit 1
}

# Helper: print elapsed time for a stage
stage_time() {
  STAGE_END=$(date +%s)
  echo "  $1 (${2}$((STAGE_END - STAGE_START))s)"
  STAGE_START=$STAGE_END
}

if [ "$NODE_ENV" = "production" ]; then
  fail "env-check" "NODE_ENV=production. Refusing to run checks against production."
fi

# ------------------------------------------------------------------
# Determine mode: lite (default ~30-60s) or heavy (lite + e2e)
#
# Override with env vars:
#   PUSH_LITE=1   → force lite (skip all detection)
#   PUSH_HEAVY=1  → force heavy
# ------------------------------------------------------------------

# Figure out what we're pushing vs the remote (used for mode detection + tsc skip)
UPSTREAM=$(git rev-parse --verify "@{push}" 2>/dev/null \
  || git merge-base HEAD origin/main 2>/dev/null \
  || echo "HEAD~1")

CHANGED=$(git diff --name-only "$UPSTREAM" HEAD 2>/dev/null || echo "")

if [ "$PUSH_LITE" = "1" ]; then
  echo "  PUSH_LITE=1 → forcing lite mode"
  MODE="lite"
elif [ "$PUSH_HEAVY" = "1" ]; then
  echo "  PUSH_HEAVY=1 → forcing heavy mode"
  MODE="heavy"
else
  # --- Hybrid detection ---
  MODE="lite"

  # Step 1 — File pattern gate (instant)
  for file in $CHANGED; do
    case "$file" in
      backend/src/routes/*|backend/src/middleware/*)
        MODE="heavy"; break ;;
      frontend/src/lib/api.ts)
        MODE="heavy"; break ;;
      frontend/src/pages/Dashboard*|frontend/src/pages/Welcome.tsx)
        MODE="heavy"; break ;;
      prisma/schema.prisma|prisma/migrations/*)
        MODE="heavy"; break ;;
      e2e/*)
        MODE="heavy"; break ;;
    esac
  done

  # Step 2 — LLM escalation for large diffs (500+ lines)
  if [ "$MODE" = "lite" ]; then
    DIFF_LINES=$(git diff "$UPSTREAM" HEAD 2>/dev/null | wc -l)
    if [ "$DIFF_LINES" -gt 500 ]; then
      echo "  Large diff ($DIFF_LINES lines), no heavy patterns — asking LLM..."
      if node scripts/should-run-e2e.mjs "$UPSTREAM"; then
        MODE="heavy"
        echo "  LLM verdict: run e2e → heavy mode"
      else
        echo "  LLM verdict: skip e2e → lite mode"
      fi
    fi
  fi
fi

# ------------------------------------------------------------------
# Detect whether any TS/TSX files changed (used to skip tsc)
# ------------------------------------------------------------------
HAS_TS_CHANGES=0
for file in $CHANGED; do
  case "$file" in
    *.ts|*.tsx)
      HAS_TS_CHANGES=1; break ;;
  esac
done

# ------------------------------------------------------------------
# Environment check: can we run full checks?
# If tsc isn't available, only run static validation (migrations, lint)
# ------------------------------------------------------------------
CAN_RUN_FULL=1
if ! (cd backend && npx tsc --version) >/dev/null 2>&1; then
  CAN_RUN_FULL=0
elif ! command -v docker >/dev/null 2>&1 && ! pg_isready -h localhost -p 5432 >/dev/null 2>&1; then
  # No docker and no local postgres — can't run tests or e2e
  CAN_RUN_FULL=0
fi

if [ "$CAN_RUN_FULL" = "0" ]; then
  echo "  Full environment not available — running static checks only"
  MODE="static-only"
fi

echo "  Mode: $MODE"

STAGE_START=$(date +%s)

# ------------------------------------------------------------------
# Regenerate Prisma client so type checks match the latest schema
# ------------------------------------------------------------------
echo "  Regenerating Prisma client..."
if ! (cd backend && npx prisma generate) >$STAGE_LOG 2>&1; then
  echo "  WARNING: prisma generate failed — type checks may report false errors"
  echo "  Run 'cd backend && npx prisma generate' manually if tsc fails"
fi
stage_time "Prisma generate" ""

# ------------------------------------------------------------------
# Safe storage check (fast, no DB needed)
# Prevents raw localStorage/sessionStorage that crashes in-app browsers
# ------------------------------------------------------------------
echo "  Checking for raw storage usage..."
if bash scripts/check-safe-storage.sh >$STAGE_LOG 2>&1; then
  stage_time "Safe storage check OK" ""
else
  DETAIL=$(cat $STAGE_LOG)
  fail "safe-storage" \
    "Raw localStorage/sessionStorage usage found:" \
    "" \
    "$DETAIL" \
    "" \
    "Fix: use safeLocalStorage / safeSessionStorage from lib/safeStorage.ts" \
    "Run:  bash scripts/check-safe-storage.sh   (for details)"
fi

# ------------------------------------------------------------------
# Migration structure validation (fast, no DB needed)
# ------------------------------------------------------------------
echo "  Validating migration structure..."
if bash backend/scripts/validate-migrations.sh >$STAGE_LOG 2>&1; then
  stage_time "Migration structure OK" ""
else
  ISSUES=$(grep "❌" $STAGE_LOG || echo "Unknown migration structure error")
  fail "migration-structure" \
    "Migration file issues detected:" \
    "" \
    "$ISSUES" \
    "" \
    "Fix: add IF EXISTS to DROP statements, deduplicate timestamps," \
    "      or consolidate init migrations." \
    "Run:  bash backend/scripts/validate-migrations.sh   (for details)"
fi

# ------------------------------------------------------------------
# Schema drift check: ensure schema.prisma matches migration history
# ------------------------------------------------------------------
SHADOW_URL="${SHADOW_DATABASE_URL:-postgresql://humans:humans_secret@localhost:5432/humans_shadow}"
echo "  Checking schema drift..."
if (cd backend && npx prisma migrate diff \
    --from-migrations ./prisma/migrations \
    --to-schema-datamodel ./prisma/schema.prisma \
    --exit-code \
    --shadow-database-url "$SHADOW_URL") >$STAGE_LOG 2>&1; then
  stage_time "No schema drift detected" ""
else
  # Check if it's a missing binary vs actual drift
  if grep -q "Could not find schema-engine\|Failed to fetch sha256" $STAGE_LOG 2>/dev/null; then
    echo "  WARNING: Prisma schema-engine not available — skipping drift check"
    echo "  (migration structure validation still passed)"
    STAGE_START=$(date +%s)
    # Don't fail — the static validation already passed above.
    # The full drift check will run on environments with Prisma installed.
  elif grep -q "P3018\|P3009\|P3006" $STAGE_LOG 2>/dev/null; then
    DRIFT_DETAIL=$(grep -A3 "ERROR\|DbError\|following migration" $STAGE_LOG | head -10)
    fail "schema-drift" \
      "Prisma migration error:" \
      "" \
      "$DRIFT_DETAIL" \
      "" \
      "Fix: cd backend && npx prisma migrate dev --name <description>" \
      "     or: npx prisma migrate reset  (drops DB!)"
  else
    DRIFT_DETAIL=$(head -20 $STAGE_LOG)
    fail "schema-drift" \
      "schema.prisma doesn't match migration history:" \
      "" \
      "$DRIFT_DETAIL" \
      "" \
      "Fix: cd backend && npx prisma migrate dev --name <description>"
  fi
fi

# ------------------------------------------------------------------
# Static-only mode: migration + drift checks passed, skip compile/test
# ------------------------------------------------------------------
if [ "$MODE" = "static-only" ]; then
  PUSH_END=$(date +%s)
  echo "=== Static checks passed in $((PUSH_END - PUSH_START))s (compile/test skipped — not available) ==="
  exit 0
fi

# ------------------------------------------------------------------
# Build the concurrently command list dynamically
# ------------------------------------------------------------------
LOG="$REPO_ROOT/.pre-push-run.log"
LITE_TIMEOUT="${PUSH_TIMEOUT_LITE:-90}"

# Names and commands for concurrently — built dynamically
NAMES=""
CMDS=""

add_task() {
  if [ -z "$NAMES" ]; then
    NAMES="$1"
    CMDS="$2"
  else
    NAMES="$NAMES,$1"
    # Use a NULL byte separator to handle complex commands
    CMDS="$CMDS
$2"
  fi
}

# ── TypeScript checks (skip if no .ts/.tsx files changed) ──
if [ "$HAS_TS_CHANGES" = "1" ]; then
  add_task "tsc:be" "cd backend && npx tsc --noEmit --incremental --tsBuildInfoFile .tsbuildinfo"
  add_task "tsc:fe" "cd frontend && npx tsc --noEmit --incremental --tsBuildInfoFile .tsbuildinfo"
else
  echo "  Skipping tsc — no .ts/.tsx files changed"
fi

# ── Backend unit tests ──
add_task "test:be" "cd backend && npm test"

# ── Frontend unit tests ──
add_task "test:fe" "cd frontend && npm test"

# ------------------------------------------------------------------
# Lite checks
# ------------------------------------------------------------------
if [ "$MODE" = "lite" ]; then
  echo "  Running lite checks with ${LITE_TIMEOUT}s timeout... (log: $LOG)"

  # Build the concurrently command
  eval "timeout --signal=TERM --kill-after=10 $LITE_TIMEOUT \
    npx concurrently --kill-others-on-fail \
    -n \"$NAMES\" \
    $(echo "$CMDS" | while IFS= read -r cmd; do printf ' \"%s\"' "$cmd"; done)" \
    >"$LOG" 2>&1

  LITE_EXIT=$?

  if [ $LITE_EXIT -eq 124 ]; then
    echo "TIMEOUT" > $STAGE_LOG
    fail "lite-checks-timeout" \
      "Lite checks exceeded ${LITE_TIMEOUT}s timeout and were killed." \
      "" \
      "This usually means tsc or tests are hanging." \
      "You can retry with: git push" \
      "Or increase the timeout: PUSH_TIMEOUT_LITE=120 git push" \
      "" \
      "Full log: $LOG"
  elif [ $LITE_EXIT -ne 0 ]; then
    # Strip ANSI color codes for reliable grep matching
    sed 's/\x1b\[[0-9;]*m//g' "$LOG" > $STAGE_LOG

    FAILED_CHECKS=""
    if grep -q "\[tsc:be\].*error TS" $STAGE_LOG 2>/dev/null; then
      FAILED_CHECKS="$FAILED_CHECKS backend TypeScript errors;"
    fi
    if grep -q "\[tsc:fe\].*error TS" $STAGE_LOG 2>/dev/null; then
      FAILED_CHECKS="$FAILED_CHECKS frontend TypeScript errors;"
    fi
    if grep -q "\[test:be\].*FAIL\|failing" $STAGE_LOG 2>/dev/null; then
      FAILED_CHECKS="$FAILED_CHECKS backend test failures;"
    fi
    if grep -q "\[test:fe\].*FAIL\|failing" $STAGE_LOG 2>/dev/null; then
      FAILED_CHECKS="$FAILED_CHECKS frontend test failures;"
    fi
    [ -z "$FAILED_CHECKS" ] && FAILED_CHECKS="see log for details"

    # Extract the actual error lines (from color-stripped log)
    TS_ERRORS=$(grep -h "error TS" $STAGE_LOG 2>/dev/null | head -15)
    TEST_ERRORS=$(grep -h "FAIL\|AssertionError\|Expected\|failing" $STAGE_LOG 2>/dev/null | head -10)
    DETAIL=$(printf "%s\n%s" "$TS_ERRORS" "$TEST_ERRORS" | sed '/^$/d' | head -20)
    [ -z "$DETAIL" ] && DETAIL=$(tail -20 $STAGE_LOG)

    fail "lite-checks" \
      "Failed:$FAILED_CHECKS" \
      "" \
      "$DETAIL" \
      "" \
      "Full log: $LOG"
  fi

  PUSH_END=$(date +%s)
  echo "=== Lite checks passed in $((PUSH_END - PUSH_START))s ==="
  exit 0
fi

# ------------------------------------------------------------------
# Heavy checks: lite + e2e (start servers, run playwright)
# ------------------------------------------------------------------

# Overall timeout for heavy checks (seconds). Override: PUSH_TIMEOUT=300
HEAVY_TIMEOUT="${PUSH_TIMEOUT:-180}"

# Cleanup trap — kill dev servers on exit
STARTED_SERVERS=0
DEV_PID=""
FINAL_EXIT=0

stop_servers() {
  if [ "$STARTED_SERVERS" = "1" ] && [ -n "$DEV_PID" ]; then
    echo "  Stopping dev servers..."
    pkill -P "$DEV_PID" 2>/dev/null
    kill "$DEV_PID" 2>/dev/null
    wait "$DEV_PID" 2>/dev/null
  fi
}
trap 'FINAL_EXIT=$?; stop_servers; exit $FINAL_EXIT' INT TERM
trap 'FINAL_EXIT=$?; stop_servers; exit $FINAL_EXIT' EXIT

# Start dev servers if needed
if curl -sf http://localhost:3001/health >/dev/null 2>&1 && curl -sf http://localhost:3000 >/dev/null 2>&1; then
  echo "  Dev servers already running"
else
  echo "  Starting dev servers in background..."
  STARTED_SERVERS=1
  lsof -ti :3000 -sTCP:LISTEN 2>/dev/null | xargs kill 2>/dev/null
  lsof -ti :3001 -sTCP:LISTEN 2>/dev/null | xargs kill 2>/dev/null
  sleep 1
  setsid npm run dev >$REPO_ROOT/.pre-push-e2e-servers.log 2>&1 &
  DEV_PID=$!
fi

# Add e2e task to the command list (uses extracted script)
add_task "e2e" "sh scripts/wait-and-e2e.sh $UPSTREAM"

echo "  Running heavy checks (lite + e2e) with ${HEAVY_TIMEOUT}s timeout... (log: $LOG)"

# --- Run with timeout to prevent SIGTERM from git/OS ---
# Uses `timeout` which sends SIGTERM then SIGKILL after 10s grace
eval "timeout --signal=TERM --kill-after=10 $HEAVY_TIMEOUT \
  npx concurrently --kill-others-on-fail \
  -n \"$NAMES\" \
  $(echo "$CMDS" | while IFS= read -r cmd; do printf ' \"%s\"' "$cmd"; done)" \
  >"$LOG" 2>&1

HEAVY_EXIT=$?

if [ $HEAVY_EXIT -eq 124 ]; then
  # Exit 124 = timeout expired (GNU coreutils timeout)
  echo "TIMEOUT" > $STAGE_LOG
  fail "heavy-checks-timeout" \
    "Heavy checks exceeded ${HEAVY_TIMEOUT}s timeout and were killed." \
    "" \
    "This usually means dev servers were slow to start or e2e tests hung." \
    "You can retry with: git push" \
    "Or increase the timeout: PUSH_TIMEOUT=300 git push" \
    "Or skip e2e: PUSH_LITE=1 git push" \
    "" \
    "Full log: $LOG" \
    "E2e server log: $REPO_ROOT/.pre-push-e2e-servers.log"
elif [ $HEAVY_EXIT -ne 0 ]; then
  # Strip ANSI color codes for reliable grep matching
  sed 's/\x1b\[[0-9;]*m//g' "$LOG" > $STAGE_LOG

  FAILED_CHECKS=""
  if grep -q "\[tsc:be\].*error TS" $STAGE_LOG 2>/dev/null; then
    FAILED_CHECKS="$FAILED_CHECKS backend TypeScript errors;"
  fi
  if grep -q "\[tsc:fe\].*error TS" $STAGE_LOG 2>/dev/null; then
    FAILED_CHECKS="$FAILED_CHECKS frontend TypeScript errors;"
  fi
  if grep -q "\[test:be\].*FAIL\|failing" $STAGE_LOG 2>/dev/null; then
    FAILED_CHECKS="$FAILED_CHECKS backend test failures;"
  fi
  if grep -q "\[test:fe\].*FAIL\|failing" $STAGE_LOG 2>/dev/null; then
    FAILED_CHECKS="$FAILED_CHECKS frontend test failures;"
  fi
  if grep -q "\[e2e\].*failed\|FAILED" $STAGE_LOG 2>/dev/null; then
    FAILED_CHECKS="$FAILED_CHECKS e2e test failures;"
  fi
  if grep -q "Backend failed to start\|Frontend failed to start" "$LOG" 2>/dev/null; then
    FAILED_CHECKS="$FAILED_CHECKS dev server startup failed;"
  fi
  [ -z "$FAILED_CHECKS" ] && FAILED_CHECKS="see log for details"

  TS_ERRORS=$(grep -h "error TS" $STAGE_LOG 2>/dev/null | head -15)
  TEST_ERRORS=$(grep -h "FAIL\|AssertionError\|Expected\|failing\|failed" $STAGE_LOG 2>/dev/null | head -10)
  DETAIL=$(printf "%s\n%s" "$TS_ERRORS" "$TEST_ERRORS" | sed '/^$/d' | head -20)
  [ -z "$DETAIL" ] && DETAIL=$(tail -20 $STAGE_LOG)

  fail "heavy-checks" \
    "Failed:$FAILED_CHECKS" \
    "" \
    "$DETAIL" \
    "" \
    "Full log: $LOG" \
    "E2e server log: $REPO_ROOT/.pre-push-e2e-servers.log"
fi

PUSH_END=$(date +%s)
echo "=== Heavy checks passed in $((PUSH_END - PUSH_START))s ==="
