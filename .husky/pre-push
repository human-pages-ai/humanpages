#!/bin/sh

echo "=== Pre-push checks ==="

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

if [ "$NODE_ENV" = "production" ]; then
  echo "ERROR: NODE_ENV=production. Refusing to run checks against production."
  exit 1
fi

# ------------------------------------------------------------------
# Determine mode: lite (default ~30-60s) or heavy (lite + e2e)
#
# Override with env vars:
#   PUSH_LITE=1   → force lite (skip all detection)
#   PUSH_HEAVY=1  → force heavy
# ------------------------------------------------------------------

if [ "$PUSH_LITE" = "1" ]; then
  echo "  PUSH_LITE=1 → forcing lite mode"
  MODE="lite"
elif [ "$PUSH_HEAVY" = "1" ]; then
  echo "  PUSH_HEAVY=1 → forcing heavy mode"
  MODE="heavy"
else
  # --- Hybrid detection ---
  MODE="lite"

  # Figure out what we're pushing vs the remote
  UPSTREAM=$(git rev-parse --verify "@{push}" 2>/dev/null \
    || git merge-base HEAD origin/main 2>/dev/null \
    || echo "HEAD~1")

  CHANGED=$(git diff --name-only "$UPSTREAM" HEAD 2>/dev/null || echo "")

  # Step 1 — File pattern gate (instant)
  for file in $CHANGED; do
    case "$file" in
      backend/src/routes/*|backend/src/middleware/*)
        MODE="heavy"; break ;;
      frontend/src/lib/api.ts)
        MODE="heavy"; break ;;
      frontend/src/pages/Dashboard*|frontend/src/pages/Welcome.tsx)
        MODE="heavy"; break ;;
      prisma/schema.prisma|prisma/migrations/*)
        MODE="heavy"; break ;;
      e2e/*)
        MODE="heavy"; break ;;
    esac
  done

  # Step 2 — LLM escalation for large diffs (500+ lines)
  if [ "$MODE" = "lite" ]; then
    DIFF_LINES=$(git diff "$UPSTREAM" HEAD 2>/dev/null | wc -l)
    if [ "$DIFF_LINES" -gt 500 ]; then
      echo "  Large diff ($DIFF_LINES lines), no heavy patterns — asking LLM..."
      if node scripts/should-run-e2e.mjs "$UPSTREAM"; then
        MODE="heavy"
        echo "  LLM verdict: run e2e → heavy mode"
      else
        echo "  LLM verdict: skip e2e → lite mode"
      fi
    fi
  fi
fi

echo "  Mode: $MODE"

# ------------------------------------------------------------------
# Regenerate Prisma client so type checks match the latest schema
# ------------------------------------------------------------------
echo "  Regenerating Prisma client..."
if ! (cd backend && npx prisma generate); then
  echo "  WARNING: prisma generate failed — type checks may report false errors"
  echo "  Run 'cd backend && npx prisma generate' manually if tsc fails"
fi

# ------------------------------------------------------------------
# Schema drift check: ensure schema.prisma matches migration history
# ------------------------------------------------------------------
SHADOW_URL="${SHADOW_DATABASE_URL:-postgresql://humans:humans_secret@localhost:5432/humans_shadow}"
echo "  Checking schema drift..."
if (cd backend && npx prisma migrate diff \
    --from-migrations ./prisma/migrations \
    --to-schema-datamodel ./prisma/schema.prisma \
    --exit-code \
    --shadow-database-url "$SHADOW_URL" 2>&1); then
  echo "  No schema drift detected"
else
  echo ""
  echo "  ERROR: Schema drift detected!"
  echo "  Fields in schema.prisma don't match migrations."
  echo "  Run: cd backend && npx prisma migrate dev --name <description>"
  exit 1
fi

# ------------------------------------------------------------------
# Lite checks: tsc (parallel) + backend unit tests
# ------------------------------------------------------------------
LOG="/tmp/human-pages-pre-push.log"

if [ "$MODE" = "lite" ]; then
  echo "  Running lite checks... (log: $LOG)"
  npx concurrently --kill-others-on-fail \
    -n "tsc:be,tsc:fe,test" \
    "cd backend && npx tsc --noEmit" \
    "cd frontend && npx tsc --noEmit" \
    "cd backend && npm test" \
    >"$LOG" 2>&1

  if [ $? -ne 0 ]; then
    echo "  Lite checks failed — see $LOG"
    tail -40 "$LOG"
    exit 1
  fi

  echo "=== Lite checks passed ==="
  exit 0
fi

# ------------------------------------------------------------------
# Heavy checks: lite + e2e (start servers, run playwright)
# ------------------------------------------------------------------

# Cleanup trap — kill dev servers on exit
STARTED_SERVERS=0
DEV_PID=""
FINAL_EXIT=0

stop_servers() {
  if [ "$STARTED_SERVERS" = "1" ] && [ -n "$DEV_PID" ]; then
    echo "  Stopping dev servers..."
    pkill -P "$DEV_PID" 2>/dev/null
    kill "$DEV_PID" 2>/dev/null
    wait "$DEV_PID" 2>/dev/null
  fi
}
trap 'FINAL_EXIT=$?; stop_servers; exit $FINAL_EXIT' INT TERM
trap 'FINAL_EXIT=$?; stop_servers; exit $FINAL_EXIT' EXIT

# Start dev servers if needed
if curl -sf http://localhost:3001/health >/dev/null 2>&1 && curl -sf http://localhost:3000 >/dev/null 2>&1; then
  echo "  Dev servers already running"
else
  echo "  Starting dev servers in background..."
  STARTED_SERVERS=1
  lsof -ti :3000 -sTCP:LISTEN 2>/dev/null | xargs kill 2>/dev/null
  lsof -ti :3001 -sTCP:LISTEN 2>/dev/null | xargs kill 2>/dev/null
  sleep 1
  npm run dev >/tmp/human-pages-e2e-servers.log 2>&1 &
  DEV_PID=$!
fi

echo "  Running heavy checks (lite + e2e)... (log: $LOG)"
npx concurrently --kill-others-on-fail \
  -n "tsc:be,tsc:fe,test,e2e" \
  "cd backend && npx tsc --noEmit" \
  "cd frontend && npx tsc --noEmit" \
  "cd backend && npm test" \
  "i=0; while [ \$i -lt 60 ]; do curl -sf http://localhost:3001/health >/dev/null 2>&1 && break; i=\$((i+1)); sleep 1; done && i=0; while [ \$i -lt 60 ]; do curl -sf http://localhost:3000 >/dev/null 2>&1 && break; i=\$((i+1)); sleep 1; done && npx playwright test --config e2e/playwright.config.ts" \
  >"$LOG" 2>&1

if [ $? -ne 0 ]; then
  echo "  Heavy checks failed — see $LOG"
  tail -40 "$LOG"
  exit 1
fi

echo "=== Heavy checks passed ==="
