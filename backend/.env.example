# ===========================================
# Humans Marketplace - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.
# In production, use Infisical to manage secrets.

# --- Database ---
# connection_limit controls Prisma's pool size per process (tune based on PM2 instances)
DATABASE_URL="postgresql://user:password@localhost:5432/humans_marketplace?connection_limit=5"
# directUrl bypasses connection poolers (PgBouncer etc.) for migrations and introspection
DIRECT_DATABASE_URL="postgresql://user:password@localhost:5432/humans_marketplace"

# --- Authentication ---
JWT_SECRET="generate-a-strong-random-secret"

# --- Server ---
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# --- OAuth: Google ---
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- OAuth: LinkedIn ---
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# --- Frontend URL (for OAuth redirects and email links) ---
FRONTEND_URL=http://localhost:3000

# --- Email (Resend) ---
RESEND_API_KEY=your-resend-api-key
FROM_EMAIL=hello@humanpages.ai
FROM_NAME=HumanPages

# --- Email Fallback (Amazon SES SMTP, optional) ---
SES_SMTP_HOST=email-smtp.ap-southeast-2.amazonaws.com
SES_SMTP_PORT=465
SES_SMTP_USER=your-ses-smtp-username
SES_SMTP_PASS=your-ses-smtp-password

# --- Gitcoin Passport (Proof of Humanity) ---
GITCOIN_SCORER_API_KEY=your-api-key
GITCOIN_SCORER_ID=your-scorer-id

# --- Cloudflare Turnstile (CAPTCHA) ---
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# --- Analytics (PostHog, optional) ---
POSTHOG_KEY=

# --- Infisical (production only) ---
# INFISICAL_CLIENT_ID=your-infisical-client-id
# INFISICAL_CLIENT_SECRET=your-infisical-client-secret
# INFISICAL_PROJECT_ID=your-infisical-project-id
