{
  "name": "humans-backend",
  "version": "1.0.0",
  "description": "Backend API for the Humans AI-to-Human marketplace",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:apply": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "tsx src/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.993.0",
    "@aws-sdk/s3-request-presigner": "^3.993.0",
    "@infisical/sdk": "^4.0.6",
    "@prisma/client": "^5.10.0",
    "@resvg/resvg-js": "^2.6.2",
    "@rollup/rollup-linux-arm64-gnu": "^4.59.0",
    "@x402/core": "^2.3.1",
    "@x402/evm": "^2.3.1",
    "@x402/express": "^2.3.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "google-auth-library": "^9.6.0",
    "helmet": "^8.1.0",
    "i18next": "^25.8.4",
    "jsonwebtoken": "^9.0.2",
    "leo-profanity": "^1.9.0",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.0",
    "openai": "^6.22.0",
    "pino": "^10.3.0",
    "pino-http": "^11.0.0",
    "posthog-node": "^5.24.11",
    "resend": "^6.9.1",
    "sharp": "^0.34.5",
    "viem": "^2.45.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.11.16",
    "@types/nodemailer": "^7.0.9",
    "@types/pg": "^8.16.0",
    "@types/pino-http": "^5.8.4",
    "@types/supertest": "^6.0.3",
    "pg": "^8.18.0",
    "prisma": "^5.10.0",
    "supertest": "^7.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  }
}
