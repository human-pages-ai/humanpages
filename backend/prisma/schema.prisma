generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// Rate type for pricing
enum RateType {
  HOURLY
  FLAT_TASK
  NEGOTIABLE
}

// Work arrangement preference
enum WorkMode {
  REMOTE
  ONSITE
  HYBRID
}

// Payment mode for jobs
enum PaymentMode {
  ONE_TIME
  STREAM
}

// Stream payment interval
enum StreamInterval {
  HOURLY
  DAILY
  WEEKLY
}

// Stream payment method
enum StreamMethod {
  SUPERFLUID
  MICRO_TRANSFER
}

// Stream tick verification status
enum TickStatus {
  PENDING
  VERIFIED
  MISSED
  SKIPPED
}

// Agent lifecycle status
enum AgentStatus {
  PENDING
  ACTIVE
  SUSPENDED
  BANNED
}

enum HumanStatus {
  ACTIVE
  FLAGGED
  SUSPENDED
  BANNED
}

enum HumanRole {
  USER
  STAFF
  ADMIN
}

enum PostingGroupStatus {
  PENDING
  JOINED
  POSTED
  REJECTED
  SKIPPED
}

enum FiatPaymentPlatform {
  WISE
  VENMO
  PAYPAL
  CASHAPP
  REVOLUT
  ZELLE
  MONZO
  N26
  MERCADOPAGO
}

// How the agent activated their account
enum ActivationMethod {
  AUTO
  SOCIAL
  PAYMENT
  ADMIN
}

// Reason for reporting an agent
enum ReportReason {
  SPAM
  FRAUD
  HARASSMENT
  IRRELEVANT
  OTHER
}

// Status of an abuse report
enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
}

// Lead status lifecycle
enum LeadStatus {
  NEW
  VERIFIED
  OUTREACH_READY
  CONTACTED
  REPLIED
  ENGAGED
  CONVERTED
  REJECTED
  STALE
  BLOCKED
}

// How the lead was discovered
enum LeadSource {
  MANUAL
  CSV_IMPORT
  PODCAST_MINE
  CONFERENCE
  PUBLICATION
  CATEGORY_SCAN
  REFERRAL
}

// Idle alert lifecycle
enum IdleAlertStatus {
  ACTIVE
  RESOLVED
  DISMISSED
}

// Email notification delivery mode
enum EmailDigestMode {
  REALTIME
  HOURLY
  DAILY
}

model Human {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String?  // Optional for OAuth-only users

  // ===== IDENTITY & TRUST (Human Readable) =====
  name          String   // Display name (e.g., "Alice P.")
  username      String?  @unique // Unique handle (e.g., "@alice_sf")
  bio           String?  @db.VarChar(500) // Free text pitch

  // Location
  location      String?  // City display (e.g., "San Francisco, CA")
  neighborhood  String?  // Neighborhood/district (e.g., "Mission District")
  locationGranularity String @default("city") // "city" or "neighborhood"
  locationLat   Float?   // Latitude for radius search
  locationLng   Float?   // Longitude for radius search

  // ===== CAPABILITIES (Bot Readable) =====
  skills        String[] @default([]) // Tags for search
  equipment     String[] @default([]) // Hardware (car, drone, camera, etc.)
  languages     String[] @default([]) // ISO codes (en, es, zh, etc.)
  yearsOfExperience Int?   // Total professional experience in years
  experienceHighlights String[] @default([]) // Top achievements from CV
  cvParsedAt    DateTime?  // When CV was last parsed
  cvConsent     Boolean    @default(false) // User consented to CV analysis
  skillSources  Json?      // Maps skill → source (cv, cv_inferred, manual)
  preferredLanguage String @default("en") // UI/email language preference
  isAvailable   Boolean  @default(true) // Open for work

  // ===== ECONOMICS (Deal Terms) =====
  minRateUsdc      Decimal? @db.Decimal(18, 6) // Minimum rate filter
  rateCurrency     String   @default("USD") // Currency for rate fields (USD, EUR, TRY, etc.)
  minRateUsdEstimate Decimal? @db.Decimal(18, 6) // Computed USD equivalent of minRateUsdc
  rateType         RateType @default(NEGOTIABLE)
  workMode         WorkMode?
  paymentPreferences String[] @default(["UPFRONT", "ESCROW", "UPON_COMPLETION"]) // Payment types accepted

  // ===== OFFER FILTERS (Anti-Spam) =====
  minOfferPrice    Decimal? @db.Decimal(18, 6) // Reject offers below this price
  maxOfferDistance Int?     // Reject offers from agents beyond this distance (km)

  // ===== COMMUNICATION =====
  contactEmail    String?
  telegram        String?
  telegramChatId  String?  // For sending notifications via bot
  whatsapp        String?  // WhatsApp number
  signal          String?  // Signal number

  // ===== PAYMENT METHODS =====
  paymentMethods  String?  // Free-text: PayPal, Venmo, Wise links, etc.

  // ===== PRIVACY =====
  hideContact          Boolean   @default(true) // Hide contact info from public profile
  featuredConsent      Boolean   @default(false) // Opt-in to be featured on homepage
  featuredInviteSentAt DateTime? // When we sent the "want to be featured?" email

  // ===== EMAIL DIGEST =====
  emailDigestMode EmailDigestMode @default(REALTIME)

  // ===== ACTIVITY & REPUTATION (System Generated) =====
  lastActiveAt  DateTime @default(now()) // For deprioritizing ghosts
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // OAuth fields
  googleId          String?  @unique
  linkedinId        String?  @unique
  linkedinHeadline  String?  // LinkedIn professional headline (e.g. "Software Engineer at Acme")
  linkedinVerified  Boolean  @default(false)
  githubId          String?  @unique
  githubVerified    Boolean  @default(false)
  githubUsername     String?  // GitHub username for display

  // Privy identity binding (one HP account = one Privy identity)
  privyDid      String?  @unique

  // Referral tracking
  referralCode  String   @unique // Short code for referral links (auto-generated via middleware)
  referredBy    String?  // ID of the human who referred this user

  // UTM attribution — tracks which campaign brought this signup
  utmSource     String?  // e.g. "telegram", "reddit", "facebook"
  utmMedium     String?  // e.g. "sponsored", "organic", "cta"
  utmCampaign   String?  // e.g. "lagos_jobnetworking", "nomad_beermoney"

  // Token invalidation for logout-all
  tokenInvalidatedAt DateTime? // All tokens issued before this time are invalid

  // Profile completion nudge tracking
  profileNudgeSentAt DateTime? // When last profile-completion reminder was sent

  // Privacy & legal compliance
  termsAcceptedAt        DateTime?
  emailVerified          Boolean    @default(false)
  emailVerificationToken String?    @unique
  emailNotifications     Boolean    @default(true)
  telegramNotifications  Boolean    @default(true)
  whatsappNotifications  Boolean    @default(true)
  analyticsOptOut        Boolean    @default(false) // GDPR: user can opt out of analytics tracking

  // Proof of humanity (Gitcoin Passport)
  humanityVerified       Boolean   @default(false)
  humanityProvider       String?                    // "gitcoin_passport"
  humanityScore          Float?                     // 0-100 score
  humanityVerifiedAt     DateTime?

  // Profile photo
  profilePhotoKey    String?   // R2 object key: "photos/{userId}/{uuid}.webp"
  profilePhotoStatus String    @default("none") // "none" | "pending" | "approved" | "rejected"
  oauthPhotoUrl      String?   // Temporary: OAuth provider photo URL for import prompt

  // Social profiles for trust verification
  linkedinUrl   String?
  twitterUrl    String?
  githubUrl     String?
  facebookUrl   String?
  instagramUrl  String?
  youtubeUrl    String?
  websiteUrl    String?

  // Social follower counts (self-reported)
  twitterFollowers   Int?
  instagramFollowers Int?
  youtubeFollowers   Int?
  tiktokUrl          String?
  tiktokFollowers    Int?
  linkedinFollowers  Int?
  facebookFollowers  Int?

  // ===== ABUSE TRACKING =====
  humanStatus     HumanStatus @default(ACTIVE) @map("status_human")
  role            HumanRole   @default(USER)
  abuseScore      Int         @default(0)
  abuseStrikes    Int         @default(0)

  // ===== STAFF CAPABILITIES =====
  isCatchAll      Boolean  @default(false) // Catch-all concierge profile injected into sparse search results
  capabilities    String[] @default([]) // CONTENT_REVIEWER, POSTER, ANALYST, CREATIVE, GROUP_MANAGER

  // ===== STAFF PAY CONFIG =====
  staffDailyRate   Decimal? @db.Decimal(10, 2) // e.g. $25/day
  staffDailyHours  Float?   // e.g. 8 hours/day (quota)

  // Relations
  wallets       Wallet[]
  services      Service[]
  jobs          Job[]
  reviews       Review[]
  agentReports  AgentReport[]
  pendingNotifications PendingNotification[]
  vouchesGiven    Vouch[] @relation("VouchesGiven")
  vouchesReceived Vouch[] @relation("VouchesReceived")
  affiliate       Affiliate?
  affiliateReferral AffiliateReferral?
  feedback        Feedback[]
  humanReportsReceived HumanReport[] @relation("ReportsReceived")
  humanReportsGiven    HumanReport[] @relation("ReportsGiven")
  listingApplications ListingApplication[]
  careerApplications  CareerApplication[]
  postingCompletions PostingGroup[] @relation("PostingCompletions")
  staffApiKey     StaffApiKey?
  timeEntries     TimeEntry[]
  staffPayments   StaffPayment[]
  hoursAdjustments HoursAdjustment[]
  paymentsCreated StaffPayment[] @relation("PaymentCreator")
  adjustmentsReviewed HoursAdjustment[] @relation("AdjustmentReviewer")
  scheduleAssigned  PublicationSchedule[] @relation("ScheduleAssigned")
  scheduleCompleted PublicationSchedule[] @relation("ScheduleCompleted")
  staffActivities   StaffActivity[]
  idleAlerts        IdleAlert[]
  assignedLeads     InfluencerLead[] @relation("LeadAssignment")
  fiatPaymentMethods FiatPaymentMethod[]
  educations    Education[]
  certificates  Certificate[]
  pushSubscriptions PushSubscription[]

  // Indexes for fast agent search
  @@index([skills])
  @@index([locationLat, locationLng])
  @@index([neighborhood])
  @@index([isAvailable])
  @@index([lastActiveAt])
  @@index([isAvailable, lastActiveAt])
  @@index([humanStatus])
}

model FiatPaymentMethod {
  id        String               @id @default(cuid())
  humanId   String
  human     Human                @relation(fields: [humanId], references: [id], onDelete: Cascade)
  platform  FiatPaymentPlatform
  handle    String               // Username, email, or link for the platform
  label     String?              // Optional display label
  isPrimary Boolean              @default(false)
  createdAt DateTime             @default(now())

  @@unique([humanId, platform, handle])
  @@index([platform, handle])
}

model Education {
  id          String   @id @default(cuid())
  humanId     String
  institution String
  country     String?
  degree      String?
  field       String?
  year        Int?
  source      String   @default("manual") // "manual" | "cv"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  human       Human    @relation(fields: [humanId], references: [id], onDelete: Cascade)

  @@index([humanId])
}

model Certificate {
  id        String   @id @default(cuid())
  humanId   String
  name      String
  issuer    String?
  year      Int?
  source    String   @default("manual") // "manual" | "cv"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  human     Human    @relation(fields: [humanId], references: [id], onDelete: Cascade)

  @@index([humanId])
}

// Job status flow:
// One-time upfront (crypto):        PENDING -> ACCEPTED -> PAID -> COMPLETED
// One-time upfront (off-chain):     PENDING -> ACCEPTED -> PAYMENT_CLAIMED -> PAID -> COMPLETED
// One-time upon-completion (crypto): PENDING -> ACCEPTED -> COMPLETED -> PAID
// One-time upon-completion (off-chain): PENDING -> ACCEPTED -> COMPLETED -> PAYMENT_CLAIMED -> PAID
// Stream:   PENDING -> ACCEPTED -> STREAMING -> PAUSED -> COMPLETED
// Cancel:   PENDING/ACCEPTED/PAYMENT_CLAIMED/PAUSED -> CANCELLED
// Dispute:  PAYMENT_CLAIMED/PAID/COMPLETED/PAUSED -> DISPUTED
enum JobStatus {
  PENDING           // Agent created offer, waiting for human to accept
  ACCEPTED          // Human accepted, waiting for payment
  REJECTED          // Human rejected the offer
  PAYMENT_CLAIMED   // Agent claims off-chain payment sent, awaiting human confirmation
  PAID              // Payment verified (on-chain) or confirmed (off-chain)
  STREAMING         // Stream payment active (Superfluid flow or micro-transfers)
  PAUSED            // Stream paused (flow deleted or tick missed)
  SUBMITTED         // Human submitted work for review, waiting for agent approval
  COMPLETED         // Work done
  CANCELLED         // Cancelled by either party (before money/work exchanged)
  DISPUTED          // Something went wrong (after money/work exchanged)
}

enum DisputeType {
  PRE_PAYMENT       // Dispute raised before any payment (e.g. SUBMITTED, PAYMENT_CLAIMED)
  POST_PAYMENT      // Dispute raised after payment (e.g. PAID, COMPLETED)
}

model Agent {
  id                String    @id @default(cuid())
  name              String
  description       String?   @db.VarChar(500)
  websiteUrl        String?
  contactEmail      String?
  apiKeyHash        String                    // bcrypt hash of full API key
  apiKeyPrefix      String    @unique         // first 8 chars for lookup
  domainVerified    Boolean   @default(false)
  verificationToken String?                   // token for domain verification
  verifiedAt        DateTime?
  lastActiveAt      DateTime  @default(now())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // ===== ACTIVATION & GATING =====
  status              AgentStatus      @default(PENDING)
  activatedAt         DateTime?
  activationMethod    ActivationMethod?
  activationExpiresAt DateTime?
  activationTier      String           @default("BASIC") // BASIC, PRO, WHALE
  activationPlatform  String?          // "twitter", "linkedin", "github"
  socialVerificationCode String?
  socialCodeExpiresAt DateTime?
  socialPostUrl       String?          // URL of verification post
  socialAccountSize   Int?             // follower count at activation time
  paymentTxHash       String?          @unique // prevents reuse of same tx
  paymentNetwork      String?
  paymentAmount       Decimal?         @db.Decimal(18, 6)
  promoUpgradedAt     DateTime?        // Launch promo: free PRO for first 100 agents

  // ===== ERC-8004 REPUTATION REGISTRY =====
  erc8004AgentId  Int?  @unique  // Sequential ID for ERC-8004 registry. See docs/ERC-8004-MAPPING.md

  // ===== PROFILE PHOTO =====
  profilePhotoKey    String?   // R2 object key: "photos/{agentId}/{uuid}.webp"
  profilePhotoStatus String    @default("none") // "none" | "pending" | "approved" | "rejected"

  // ===== DISCOVERY / ATTRIBUTION =====
  discoverySource  String?   // "direct" | "mcp_directory" | "search" | "llm" | "blog" | "other"
  discoveryDetail  String?   @db.VarChar(500) // referrer URL, LLM name, blog post, etc.

  // ===== WEBHOOK (agent-level, for platform events) =====
  webhookUrl    String?   // Persistent webhook URL for platform events (new matches, status changes, announcements)
  webhookSecret String?   // Secret for HMAC-SHA256 signature verification

  // ===== ABUSE TRACKING =====
  abuseScore   Int @default(0)
  abuseStrikes Int @default(0)

  // Relations
  jobs    Job[]
  reports AgentReport[]
  x402Payments X402Payment[]
  listings Listing[]

  @@index([lastActiveAt])
  @@index([status])
}

model X402Payment {
  id              String   @id @default(cuid())
  agentId         String
  resourceType    String   // "profile_view" | "job_offer"
  resourceId      String?  // human ID or job ID
  amountUsd       Decimal  @db.Decimal(18, 6)
  network         String   // "eip155:8453"
  paymentPayload  Json
  settled         Boolean  @default(false)
  agentIp         String?
  createdAt       DateTime @default(now())
  agent           Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId, createdAt])
  @@index([resourceType, createdAt])
}

model AgentReport {
  id              String       @id @default(cuid())
  agentId         String
  reporterHumanId String
  jobId           String?      // optional: the specific job that triggered the report
  reason          ReportReason
  description     String?      @db.VarChar(1000)
  status          ReportStatus @default(PENDING)
  createdAt       DateTime     @default(now())

  agent   Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  reporter Human @relation(fields: [reporterHumanId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([reporterHumanId])
  @@index([agentId, status])
}

model HumanReport {
  id              String       @id @default(cuid())
  reportedHumanId String
  reporterHumanId String
  reason          ReportReason
  description     String?      @db.VarChar(1000)
  status          ReportStatus @default(PENDING)
  createdAt       DateTime     @default(now())

  reportedHuman Human @relation("ReportsReceived", fields: [reportedHumanId], references: [id], onDelete: Cascade)
  reporter      Human @relation("ReportsGiven", fields: [reporterHumanId], references: [id], onDelete: Cascade)

  @@index([reportedHumanId])
  @@index([reporterHumanId])
  @@index([reportedHumanId, status])
}

model PendingNotification {
  id        String   @id @default(cuid())
  humanId   String
  type      String   // "job_offer" | "job_message"
  payload   Json
  createdAt DateTime @default(now())
  sentAt    DateTime?

  human Human @relation(fields: [humanId], references: [id], onDelete: Cascade)

  @@index([humanId, sentAt])
  @@index([sentAt, createdAt])
}

model NotificationOutbox {
  id        String   @id @default(cuid())
  channel   String   // "email" | "telegram" | "webhook"
  recipient String   // email address, telegram chat ID, or webhook URL
  subject   String?  // email subject (null for telegram)
  payload   Json     // full params needed to re-send
  status    String   @default("PENDING") // PENDING | SENT | FAILED
  attempts  Int      @default(0)
  lastError String?
  nextRetryAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, nextRetryAt])
  @@index([createdAt])
}

model EmailLog {
  id        String   @id @default(cuid())
  channel   String   @default("email") // "email" | "telegram"
  recipient String   // email address or telegram chat ID
  subject   String?
  type      String?  // "job_offer" | "job_updated" | "job_message" | "verification" | "digest" | etc.
  status    String   // "SENT" | "QUEUED" | "FAILED"
  error     String?
  jobId     String?
  humanId   String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([recipient])
  @@index([jobId])
  @@index([status])
}

model Job {
  id              String    @id @default(cuid())
  humanId         String
  agentId         String    // Identifier for the AI agent/requester
  agentName       String?   // Display name for the agent

  // Registered agent (optional FK)
  registeredAgentId String?
  registeredAgent   Agent?  @relation(fields: [registeredAgentId], references: [id])

  // Job details
  title           String
  description     String
  category        String?

  // Agreed price (locked when human accepts)
  priceUsdc       Decimal   @db.Decimal(18, 6)

  // Payment details (filled when paid)
  paymentTxHash   String?   @unique // On-chain transaction hash (unique to prevent double-spend)
  paymentNetwork  String?   // e.g., "ethereum", "base", "polygon", "arbitrum"
  paymentAmount   Decimal?  @db.Decimal(18, 6) // Actual amount received
  paidAt          DateTime?
  paymentTiming   String?   @default("upfront") // "upfront" or "upon_completion"

  // ===== STREAM PAYMENT FIELDS =====
  paymentMode          PaymentMode    @default(ONE_TIME)
  streamMethod         StreamMethod?
  streamInterval       StreamInterval?
  streamRateUsdc       Decimal?       @db.Decimal(18, 6) // USD amount per interval
  streamFlowRate       String?        // Superfluid: wei/sec flow rate (stored as string because int96)
  streamMaxTicks       Int?           // Optional cap (null = indefinite)
  streamNetwork        String?        // Locked chain for all stream payments
  streamToken          String?        // Locked token (e.g. "USDC")
  streamSuperToken     String?        // Superfluid: Super Token contract address (e.g. USDCx)
  streamSenderAddress  String?        // Agent's wallet address (for flow verification)
  streamStartedAt      DateTime?      // When streaming began
  streamPausedAt       DateTime?      // When paused
  streamEndedAt        DateTime?      // When stopped
  streamTickCount      Int            @default(0) // Total verified ticks/checkpoints
  streamMissedTicks    Int            @default(0) // Consecutive misses (micro-transfer)
  streamTotalPaid      Decimal?       @db.Decimal(18, 6) // Running total paid
  streamGraceTicks     Int            @default(1) // Misses before auto-pause (micro-transfer)
  streamContractId     String?        // Future: Sablier stream ID

  // Webhook callback (optional, provided by agent)
  callbackUrl     String?   // URL to POST status updates to
  callbackSecret  String?   // HMAC-SHA256 secret for signing payloads

  status          JobStatus @default(PENDING)

  // Content moderation
  moderationStatus  String  @default("approved") // "pending" | "approved" | "rejected"

  // Agent update tracking
  lastUpdatedByAgent DateTime?  // When the agent last updated the offer
  updateCount        Int        @default(0) // Number of times the offer was updated

  // Off-chain payment claim (agent asserts they paid via PayPal/Venmo/Wise/etc.)
  paymentClaimMethod  String?    // "paypal", "venmo", "wise", "bank_transfer", etc.
  paymentClaimNote    String?    // Reference number, receipt link, freeform proof
  paymentClaimedAt    DateTime?

  // Cancellation tracking
  cancelledAt     DateTime?
  cancelReason    String?
  cancelledBy     String?    // "AGENT" | "HUMAN"

  // Dispute tracking
  disputedAt      DateTime?
  disputeReason   String?
  disputedBy      String?    // "AGENT" | "HUMAN"
  disputeType     DisputeType?

  // Audit: who last moved the workflow forward
  lastActionBy    String?    // "AGENT" | "HUMAN" | "SYSTEM"

  // Timestamps
  createdAt       DateTime  @default(now())
  acceptedAt      DateTime?
  submittedAt     DateTime?
  completedAt     DateTime?
  updatedAt       DateTime  @updatedAt

  human           Human     @relation(fields: [humanId], references: [id], onDelete: Cascade)
  review          Review?
  messages        JobMessage[]
  streamTicks     StreamTick[]
  sourceApplication ListingApplication?

  @@index([humanId, status])
  @@index([agentId])
  @@index([registeredAgentId])
  @@index([status])
  @@index([createdAt])
  @@index([humanId, status, createdAt])
  @@index([paymentMode, status])
  @@index([status, streamMethod])
}

model StreamTick {
  id              String     @id @default(cuid())
  jobId           String
  tickNumber      Int
  status          TickStatus @default(PENDING)
  expectedAt      DateTime
  graceDeadline   DateTime
  txHash          String?    @unique    // micro-transfer: on-chain txHash. superfluid: null
  network         String?
  token           String?
  amount          Decimal?   @db.Decimal(18, 6)
  fromAddress     String?
  toAddress       String?
  verifiedAt      DateTime?
  confirmations   Int?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  job             Job        @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, tickNumber])
  @@index([jobId, status])
  @@index([status, graceDeadline])
}

// ERC-8004: The fields below (erc8004*) store pre-computed values for the
// ERC-8004 Reputation Registry's `giveFeedback(agentId, value, valueDecimals,
// tag1, tag2, feedbackHash)` call. They are derived from `rating` and job
// metadata at review-creation time. A future on-chain bridge can publish them
// directly without re-deriving anything.
//
// Invariants — DO NOT break:
//   • erc8004Value == rating * 20   (1★=20 … 5★=100)
//   • erc8004ValueDecimals == 0     (integer percent scale)
//   • erc8004Tag1 == "starred"      (constant for star ratings)
//   • erc8004FeedbackHash == SHA-256 of canonical feedback JSON (sorted keys)
//
// See docs/ERC-8004-MAPPING.md for the full specification.
model Review {
  id          String   @id @default(cuid())
  jobId       String   @unique
  humanId     String

  rating      Int      // 1-5 stars
  comment     String?

  // ERC-8004 pre-computed fields (see block comment above)
  erc8004Value         Int?     // Math.round((rating / 5) * 100). 1★=20, 5★=100
  erc8004ValueDecimals Int      @default(0)
  erc8004Tag1          String   @default("starred")
  erc8004Tag2          String   @default("")        // from Job.category
  erc8004FeedbackHash  String?                      // SHA-256 of canonical feedback JSON

  createdAt   DateTime @default(now())

  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  human       Human    @relation(fields: [humanId], references: [id], onDelete: Cascade)

  @@index([humanId])
  @@index([createdAt])
}

model Wallet {
  id        String   @id @default(cuid())
  humanId   String
  network   String   // e.g., "ethereum", "base", "solana", "bitcoin"
  chain     String?  // Specific chain: "BASE", "OPTIMISM", "ARBITRUM", etc.
  address   String
  label     String?  // e.g., "Main wallet", "Business"
  isPrimary Boolean  @default(false) // Preferred payment wallet
  source    String   @default("external") // "privy" | "external" | "manual_paste"
  verified  Boolean  @default(false) // true = ownership cryptographically proven (signature or Privy identity token)
  createdAt DateTime @default(now())

  human     Human    @relation(fields: [humanId], references: [id], onDelete: Cascade)

  @@unique([humanId, network, address])
  @@index([humanId, isPrimary])
  @@index([address])
}

model Service {
  id              String    @id @default(cuid())
  humanId         String
  title           String
  description     String
  category        String
  priceMin        Decimal?  @db.Decimal(10, 2)
  priceCurrency   String    @default("USD") // Currency for service price
  priceUnit       RateType?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  human           Human     @relation(fields: [humanId], references: [id], onDelete: Cascade)

  @@index([humanId])
  @@index([category])
}

model JobMessage {
  id         String   @id @default(cuid())
  jobId      String
  senderType String   // "human" or "agent"
  senderId   String   // human.id or agent.id
  senderName String   // snapshot at write time
  content    String   @db.VarChar(2000)
  createdAt  DateTime @default(now())
  job        Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
}

model OAuthState {
  token     String   @id
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email])
}

model Vouch {
  id          String   @id @default(cuid())
  voucherId   String
  voucheeId   String
  comment     String?  @db.VarChar(200)
  createdAt   DateTime @default(now())

  voucher     Human @relation("VouchesGiven", fields: [voucherId], references: [id], onDelete: Cascade)
  vouchee     Human @relation("VouchesReceived", fields: [voucheeId], references: [id], onDelete: Cascade)

  @@unique([voucherId, voucheeId])
  @@index([voucheeId])
}

// ===== REFERRAL PROGRAM =====
// Single-tier referral credits. Every user is automatically a referrer. No MLM.

enum AffiliateStatus {
  APPROVED   // Active referrer
  SUSPENDED  // Temporarily disabled (fraud, TOS violation)
}

model Affiliate {
  id              String          @id @default(cuid())
  humanId         String          @unique  // One referrer record per human
  status          AffiliateStatus @default(APPROVED)

  // Credits config (per-user overrides; defaults in app config)
  creditsPerReferral Int          @default(10)   // Credits earned per qualified signup
  bonusTier1      Int             @default(50)   // Bonus credits at 10 referrals
  bonusTier2      Int             @default(200)  // Bonus credits at 50 referrals
  bonusTier3      Int             @default(500)  // Bonus credits at 100 referrals

  // Stats (denormalized for fast reads)
  totalSignups    Int             @default(0)
  qualifiedSignups Int            @default(0) // Signups that completed profile
  totalCredits    Int             @default(0) // Total credits earned
  creditsRedeemed Int             @default(0) // Credits already redeemed

  // Admin
  suspendedAt     DateTime?
  suspendedReason String?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relations
  human           Human           @relation(fields: [humanId], references: [id], onDelete: Cascade)
  referrals       AffiliateReferral[]
  creditLedger    AffiliateCredit[]

  @@index([status])
}

model AffiliateReferral {
  id              String    @id @default(cuid())
  affiliateId     String
  referredHumanId String    @unique // Each human can only be referred once
  qualified       Boolean   @default(false) // True when profile is completed
  qualifiedAt     DateTime?

  // Fraud detection
  ipAddress       String?
  userAgent       String?

  // Credits
  creditsAwarded  Int      @default(0) // Credits earned for this referral
  creditsClaimed  Boolean  @default(false)

  createdAt       DateTime  @default(now())

  affiliate       Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  referredHuman   Human     @relation(fields: [referredHumanId], references: [id], onDelete: Cascade)

  @@index([affiliateId, qualified])
  @@index([affiliateId, createdAt])
}

model AffiliateCredit {
  id              String   @id @default(cuid())
  affiliateId     String
  credits         Int      // Number of credits
  type            String   @default("referral") // "referral" | "bonus_tier1" | "bonus_tier2" | "bonus_tier3"
  description     String?

  createdAt       DateTime @default(now())

  affiliate       Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@index([affiliateId])
  @@index([affiliateId, type])
}

// ===== USER FEEDBACK & BUG REPORTS =====

enum FeedbackType {
  BUG
  FEATURE
  FEEDBACK
}

enum FeedbackStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model Feedback {
  id              String         @id @default(cuid())
  humanId         String?        // Nullable: allow anonymous feedback
  type            FeedbackType   @default(FEEDBACK)
  category        String?        // "ui", "performance", "payments", "jobs", "search", "other"
  title           String?        @db.VarChar(200)
  description     String         @db.VarChar(5000)
  sentiment       Int?           // 1-5 emoji scale

  // Bug-report fields
  stepsToReproduce  String?      @db.VarChar(2000)
  expectedBehavior  String?      @db.VarChar(1000)
  actualBehavior    String?      @db.VarChar(1000)
  severity          String?      // "low" | "medium" | "high" | "critical"

  // Auto-captured context
  pageUrl         String?
  browser         String?
  os              String?
  viewport        String?        // "1920x1080"
  userAgent       String?
  appVersion      String?
  screenshotData  String?        @db.Text // base64 data URI
  diagnostics     Json?          // Auto-captured environment diagnostics (wallet state, in-app browser, etc.)

  // Admin processing
  status          FeedbackStatus @default(NEW)
  adminNotes      String?        @db.VarChar(2000)

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  human           Human?         @relation(fields: [humanId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([humanId])
}

// ===== JOB BOARD =====

enum ListingStatus {
  OPEN
  CLOSED
  EXPIRED
  CANCELLED
}

enum ApplicationStatus {
  PENDING
  PENDING_RECONFIRM
  OFFERED
  REJECTED
  WITHDRAWN
}

model Listing {
  id               String        @id @default(cuid())
  agentId          String
  agent            Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)

  title            String
  description      String        @db.VarChar(5000)
  category         String?
  budgetUsdc       Decimal       @db.Decimal(18, 6)
  requiredSkills   String[]      @default([])
  requiredEquipment String[]     @default([])
  location         String?
  locationLat      Float?
  locationLng      Float?
  radiusKm         Int?
  workMode         WorkMode?

  status           ListingStatus @default(OPEN)
  expiresAt        DateTime
  maxApplicants    Int?
  isPro            Boolean       @default(false) // Denormalized from agent tier at creation time
  budgetFlexible   Boolean       @default(false) // If true, budget is negotiable (shown as "$X+")

  imageKey         String?       // R2 object key for listing cover image
  imageStatus      String        @default("none") // none | pending | approved | rejected

  callbackUrl      String?
  callbackSecret   String?

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  applications     ListingApplication[]
  links            ListingLink[]

  @@index([status, isPro, createdAt])
  @@index([agentId])
  @@index([status, expiresAt])
  @@index([requiredSkills])
}

model ListingLink {
  id        String   @id @default(cuid())
  code      String   @unique           // 6-char lowercase: a-z, 2-9 (no 0/o/1/l/i)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  label     String?                    // Admin note: "tg-manila", "fb-cebu", etc.
  clicks    Int      @default(0)       // Simple counter, incremented on each page view via this code

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([listingId])
}

model ListingApplication {
  id          String            @id @default(cuid())
  listingId   String
  listing     Listing           @relation(fields: [listingId], references: [id], onDelete: Cascade)
  humanId     String
  human       Human             @relation(fields: [humanId], references: [id], onDelete: Cascade)

  pitch       String            @db.VarChar(500)
  status      ApplicationStatus @default(PENDING)

  jobId       String?           @unique // Set when offer is made, links to created Job
  job         Job?              @relation(fields: [jobId], references: [id])

  /// Snapshot of material listing terms at time of application.
  /// Captured on apply so humans can compare if the listing is later updated.
  listingSnapshot Json?

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([listingId, humanId])
  @@index([humanId])
  @@index([listingId, status])
}

// ===== CAREERS PAGE APPLICATIONS =====
// Internal team applications from /careers (NOT agent job-board listings).
// Stored separately from ListingApplication which is for agent-created posts.

enum CareerApplicationStatus {
  PENDING
  REVIEWED
  CONTACTED
  REJECTED
  HIRED
}

model CareerApplication {
  id              String                   @id @default(cuid())
  humanId         String
  human           Human                    @relation(fields: [humanId], references: [id], onDelete: Cascade)

  positionId      String                   // e.g. "content-creator", "software-engineer", "general"
  positionTitle   String                   // Snapshot at submission time

  about           String                   @db.VarChar(500)  // "What excites you about this role?"
  portfolioUrl    String?                  @db.VarChar(500)  // Optional link to work
  availability    String                   @default("flexible") // "flexible" | "part-time" | "full-time"

  status          CareerApplicationStatus  @default(PENDING)
  adminNotes      String?                  @db.VarChar(2000)

  utmSource       String?                  // Recruiter attribution (from ?utm_source=)

  // Fraud / abuse prevention
  ipAddress       String?
  userAgent       String?

  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  @@unique([humanId, positionId])  // One application per position per person
  @@index([status])
  @@index([positionId])
  @@index([createdAt])
}

// ===== POSTING QUEUE =====

model StaffApiKey {
  id           String   @id @default(cuid())
  humanId      String   @unique
  apiKeyPrefix String   @unique   // first 8 chars for O(1) lookup
  apiKeyHash   String             // bcrypt hash of full key
  createdBy    String             // admin who generated
  createdAt    DateTime @default(now())

  human Human @relation(fields: [humanId], references: [id], onDelete: Cascade)
}

model TimeEntry {
  id        String    @id @default(cuid())
  humanId   String
  clockIn   DateTime  @default(now())
  clockOut  DateTime?
  duration  Int?      // minutes, computed on clock-out
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  human Human @relation(fields: [humanId], references: [id], onDelete: Cascade)

  @@index([humanId, clockIn])
}

// ===== STAFF PAYMENT & HOURS ADJUSTMENT =====

enum AdjustmentStatus {
  PENDING
  APPROVED
  REJECTED
}

model StaffPayment {
