model AdCopy {
  id        String   @id @default(cuid())
  adNumber  Int
  language  String
  title     String
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  groups PostingGroup[]

  @@unique([adNumber, language])
}

model PostingGroup {
  id            String             @id @default(cuid())
  name          String
  url           String             @unique
  adId          String
  language      String
  country       String
  status        PostingGroupStatus @default(PENDING)
  datePosted    DateTime?
  notes         String?            @db.Text
  taskType      String             @default("fb_post")
  campaign      String?
  priority      Int                @default(0)
  completedById String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  ad          AdCopy @relation(fields: [adId], references: [id])
  completedBy Human? @relation("PostingCompletions", fields: [completedById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([adId, language])
  @@index([country])
  @@index([taskType])
  @@index([campaign])
  @@index([priority])
  @@index([completedById, datePosted])
}

// ===== CONTENT PIPELINE =====
// Blog engine → dashboard content items for review, approval, and publishing.
// One ContentItem per platform per source topic (a trending topic = up to 3 rows).

enum ContentStatus {
  DRAFT
  REVIEW
  APPROVED
  PUBLISHED
  REJECTED
}

enum ContentPlatform {
  TWITTER
  LINKEDIN
  BLOG
}

model ContentItem {
  id              String          @id @default(cuid())
  sourceTitle     String
  sourceUrl       String?
  source          String?
  relevanceScore  Int?
  whyUs           String?         @db.Text
  platform        ContentPlatform
  tweetDraft      String?         @db.Text
  linkedinSnippet String?         @db.Text
  blogTitle       String?
  blogSlug        String?         @unique
  blogBody        String?         @db.Text
  blogExcerpt     String?         @db.VarChar(500)
  blogReadingTime String?
  metaDescription String?         @db.VarChar(300)
  imageR2Key      String?
  isFeatured      Boolean         @default(false)
  status          ContentStatus   @default(DRAFT)
  publishedAt     DateTime?
  publishedUrl    String?
  publishError    String?
  manualInstructions String?      @db.Text
  devtoUrl          String?
  devtoArticleId    String?
  hashnodeUrl       String?
  hashnodePostId    String?
  crosspostErrors   Json?
  approvedById    String?
  approvedAt      DateTime?
  rejectionReason String?         @db.Text
  rejectedById    String?
  rejectedAt      DateTime?
  schedule        PublicationSchedule[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([status])
  @@index([platform, status])
  @@index([blogSlug])
  @@index([createdAt])
}

// ===== VIDEO PIPELINE =====

enum VideoTier {
  NANO
  DRAFT
  FINAL
}

enum VideoStatus {
  GENERATING
  DRAFT
  READY
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

model Video {
  id               String       @id @default(cuid())
  title            String
  slug             String       @unique
  description      String?      @db.Text
  conceptSnapshot  Json         // frozen concept (title, body, frontmatter, brief)
  scriptSnapshot   Json?        // frozen VideoScript JSON
  tier             VideoTier    @default(NANO)
  status           VideoStatus  @default(GENERATING)
  durationSeconds  Float?
  aspectRatio      String       @default("9:16")
  videoR2Key       String?      // "videos/{id}/final.mp4"
  thumbnailR2Key   String?      // "videos/{id}/thumb.webp"
  estimatedCostUsd Float?
  conceptSlug      String?      // link back to pipeline concept
  generatedAt      DateTime?
  assets           VideoAsset[]
  schedule         PublicationSchedule[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([status])
  @@index([tier])
  @@index([conceptSlug])
}

model VideoAsset {
  id          String   @id @default(cuid())
  videoId     String
  r2Key       String
  assetType   String   // "video" | "thumbnail" | "scene_image" | "scene_clip" | "audio"
  filename    String
  contentType String
  fileSize    Int?
  sceneNumber Int?
  createdAt   DateTime @default(now())

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId])
  @@index([assetType])
}

// ===== VIDEO JOB QUEUE =====

enum VideoJobType {
  PREVIEW
  PRODUCE
}

enum VideoJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  CHECKPOINT
}

model VideoJob {
  id             String         @id @default(cuid())
  conceptSlug    String
  jobType        VideoJobType
  tier           String         @default("nano")
  status         VideoJobStatus @default(PENDING)
  claimedAt      DateTime?
  completedAt    DateTime?
  errorMessage   String?        @db.Text
  logTail        String?        @db.Text
  pipelineStep   String?
  progressPct    Int?
  outputDir      String?
  stepNumber     Int?
  stepName       String?
  parentJobId    String?
  stepOutput     String?        @db.Text
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  parentJob      VideoJob?      @relation("JobSteps", fields: [parentJobId], references: [id])
  stepJobs       VideoJob[]     @relation("JobSteps")

  @@index([status, createdAt])
  @@index([conceptSlug, status])
  @@index([parentJobId])
}

// ===== UNIFIED PUBLICATION SCHEDULE =====
// One model for all content types: videos, blog posts, tweets, LinkedIn posts, image posts, etc.

enum PublishPlatform {
  TIKTOK
  YOUTUBE
  INSTAGRAM
  LINKEDIN
  TWITTER
  FACEBOOK
  BLOG
}

enum PublishContentType {
  VIDEO
  ARTICLE
  SHORT_POST
  IMAGE_POST
}

enum PublicationStatus {
  DRAFT
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
  CANCELLED
}

model PublicationSchedule {
  id             String   @id @default(cuid())

  // Polymorphic content reference (exactly one should be set, or standalone)
  videoId        String?
  video          Video?   @relation(fields: [videoId], references: [id], onDelete: Cascade)
  contentItemId  String?
  contentItem    ContentItem? @relation(fields: [contentItemId], references: [id], onDelete: Cascade)

  // Standalone post fields (for image posts, ad hoc social)
  title          String?
  body           String?  @db.Text
  imageR2Key     String?

  platform       PublishPlatform
  contentType    PublishContentType

  // Schedule
  scheduledAt    DateTime?   // future: when to publish
  publishedAt    DateTime?   // past: when actually published

  // Auto vs manual
  isAuto         Boolean  @default(false) // true = auto-publish via API

  // Result
  status         PublicationStatus @default(DRAFT)
  publishedUrl   String?
  errorMessage   String?
  platformMeta   Json?    // platform-specific IDs/metadata

  // Who
  assignedToId   String?  // for manual items, who should do it
  assignedTo     Human?   @relation("ScheduleAssigned", fields: [assignedToId], references: [id], onDelete: SetNull)
  completedById  String?  // who actually did it
  completedBy    Human?   @relation("ScheduleCompleted", fields: [completedById], references: [id], onDelete: SetNull)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status, scheduledAt])
  @@index([platform, status])
  @@index([videoId])
  @@index([contentItemId])
}

// ===== CONTENT MODERATION =====

model ModerationQueue {
  id           String    @id @default(cuid())
  contentType  String    // "profile_photo" | "job_posting" | "human_report" | "agent_report"
  contentId    String    // humanId (for photos), jobId, reportId
  status       String    @default("pending") // "pending" | "approved" | "rejected" | "error"
  result       Json?     // Full OpenAI moderation response for audit trail
  errorMessage String?   // If status=error, why it failed
  attempts     Int       @default(0)
  reviewedAt   DateTime?
  notifiedAt   DateTime? // When delay notification was sent to human (prevents duplicates)
  createdAt    DateTime  @default(now())

  @@index([status, createdAt])
  @@index([contentType, contentId])
}

// ===== STAFF PRODUCTIVITY TRACKING =====

model StaffActivity {
  id         String   @id @default(cuid())
  humanId    String
  actionType String   // posting_posted, content_approved, clock_in, etc.
  entityType String?  // PostingGroup, ContentItem, TimeEntry
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  human Human @relation(fields: [humanId], references: [id], onDelete: Cascade)

  @@index([humanId, createdAt])
  @@index([createdAt])
}

model IdleAlert {
  id            String          @id @default(cuid())
  humanId       String
  status        IdleAlertStatus @default(ACTIVE)
  idleSince     DateTime
  idleMinutes   Int
  resolvedAt    DateTime?
  dismissedById String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  human Human @relation(fields: [humanId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([humanId, status])
  @@index([createdAt])
}

model InfluencerLead {
  id             String     @id @default(cuid())

  // Core info
  name           String
  platforms      String[]   @default([])
  handle         String?
  followers      String?
  email          String?
  phone          String?
  contactUrl     String?
  focusAreas     String?
  whyRelevant    String?
  notes          String?

  // Classification
  list           String     // e.g. "ai-agents-futureofwork", "hr", "tech"
  country        String?
  language       String?

  // Deduplication
  dedupeKey      String     @unique

  // Source tracking
  source         LeadSource @default(CSV_IMPORT)
  sourceDetail   String?
  sourceUrl      String?

  // Status
  status         LeadStatus @default(NEW)

  // Outreach
  outreachMessage  String?
  outreachSentAt   DateTime?
  outreachChannel  String?
  lastContactAt    DateTime?
  responseNotes    String?

  // Activity monitoring
  lastActivityAt      DateTime?
  lastActivityUrl     String?
  activityCheckedAt   DateTime?

  // Pipeline metadata
  pipelinePhase    String?
  pipelineRunId    String?
  competitorCleared Boolean @default(false)

  // Admin
  assignedToId   String?
  assignedTo     Human?   @relation("LeadAssignment", fields: [assignedToId], references: [id])
  adminNotes     String?

  // Timestamps
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
  @@index([list])
  @@index([source])
  @@index([assignedToId])
  @@index([createdAt])
  @@index([list, status])
}

// ─── Marketing Ops ───

model MktOpsLog {
  id         String   @id @default(uuid())
  timestamp  DateTime @default(now())
  event      String   // "claude-call", "slack-dm-sent", "telegram-sent", "follow-up", "escalation", etc.
  staff      String?
  prompt     String?
  response   String?
  model      String?
  durationMs Int?
  details    Json     @default("{}")

  @@index([timestamp])
  @@index([staff])
  @@index([event])
}

model MktOpsDecision {
  id            String    @id @default(uuid())
  createdAt     DateTime  @default(now())
  resolvedAt    DateTime?
  staff         String?
  question      String
  context       String
  options       Json
  chosen        String?
  telegramMsgId Int?
  status        String    @default("pending") // pending, resolved, expired

  @@index([status])
  @@index([createdAt])
}

model MktOpsConfig {
  id        String   @id @default(uuid())
  key       String   @unique // "staff-profiles", "strategy", "daily-procedures"
  value     Json
  updatedAt DateTime @updatedAt
  updatedBy String?
}

// ─── Watch Dog: AI Error Monitoring ────────────────────────────────
model MonitoredError {
  id            String   @id @default(uuid())
  fingerprint   String   @unique // hash of error type + normalized message
  level         Int      // pino level: 50=error, 60=fatal
  errorType     String?  // e.g. "TypeError", "PrismaClientKnownRequestError"
  message       String   // raw error message
  firstSeenAt   DateTime
  lastSeenAt    DateTime
  occurrences   Int      @default(1)

  // AI analysis
  aiAnalysis    String?  // Claude's explanation + suggested fix
  aiAnalyzedAt  DateTime?

  // Status tracking
  status        String   @default("new") // new | alerted | acknowledged | resolved | ignored
  alertedAt     DateTime?
  acknowledgedAt DateTime?
  resolvedAt    DateTime?

  // Sample data
  samplePayload Json?    // raw log entry for context

  // Auto-fix (self-healing)
  autoFixStatus      String?   // none | diagnosing | proposed | applying | testing | staged | approved | merged | failed | rejected
  autoFixProposal    String?   // proposed diff from Claude Code
  autoFixBranch      String?   // git branch name where fix is staged
  autoFixTestOutput  String?   // tsc + test output for debugging
  autoFixAttemptedAt DateTime?
  autoFixMergedAt    DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([lastSeenAt])
  @@index([fingerprint])
}

// Web Push notification subscriptions
// SECURITY NOTE: p256dh and auth are cryptographic material. If the DB is compromised,
// an attacker could send spoofed push notifications (phishing) to users' devices.
// These fields should be encrypted at rest via database-level encryption (e.g., PostgreSQL TDE)
// or application-level encryption if available.
model PushSubscription {
  id        String   @id @default(cuid())
  humanId   String
  human     Human    @relation(fields: [humanId], references: [id], onDelete: Cascade)
  endpoint  String   @db.Text // Browser push endpoints (Google/Apple/Mozilla) can be 500+ chars
  p256dh    String   // ECDH public key for payload encryption
  auth      String   // Auth secret for payload encryption
  userAgent String?
  createdAt DateTime @default(now())

  @@unique([humanId, endpoint])
}

// Persistent queue for push notification delivery.
// Uses a DB-based outbox pattern with polling worker (no Redis/BullMQ dependency).
model PushNotificationJob {
  id        String   @id @default(cuid())
  humanId   String
  title     String
  body      String
  url       String
  status    String   @default("PENDING") // PENDING, SENT, FAILED
  attempts  Int      @default(0)
  lastError String?
  createdAt DateTime @default(now())

  @@index([status])
}

// Cached geocoding results to avoid repeated Nominatim calls
model GeoCache {
  query       String   @id          // Normalized search text (lowercased, trimmed)
  displayName String                // Resolved name (e.g., "Richmond, Virginia, USA")
  lat         Float
  lng         Float
  createdAt   DateTime @default(now())
}
