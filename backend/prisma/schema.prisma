generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// Rate type for pricing
enum RateType {
  HOURLY
  FLAT_TASK
  NEGOTIABLE
}

// Work arrangement preference
enum WorkMode {
  REMOTE
  ONSITE
  HYBRID
}

// Payment mode for jobs
enum PaymentMode {
  ONE_TIME
  STREAM
}

// Stream payment interval
enum StreamInterval {
  HOURLY
  DAILY
  WEEKLY
}

// Stream payment method
enum StreamMethod {
  SUPERFLUID
  MICRO_TRANSFER
}

// Stream tick verification status
enum TickStatus {
  PENDING
  VERIFIED
  MISSED
  SKIPPED
}

// Agent lifecycle status
enum AgentStatus {
  PENDING
  ACTIVE
  SUSPENDED
  BANNED
}

// How the agent activated their account
enum ActivationMethod {
  SOCIAL
  PAYMENT
}

// Reason for reporting an agent
enum ReportReason {
  SPAM
  FRAUD
  HARASSMENT
  IRRELEVANT
  OTHER
}

// Status of an abuse report
enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
}

// Email notification delivery mode
enum EmailDigestMode {
  REALTIME
  HOURLY
  DAILY
}

model Human {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String?  // Optional for OAuth-only users

  // ===== IDENTITY & TRUST (Human Readable) =====
  name          String   // Display name (e.g., "Alice P.")
  username      String?  @unique // Unique handle (e.g., "@alice_sf")
  bio           String?  @db.VarChar(500) // Free text pitch
  avatarUrl     String?

  // Location
  location      String?  // City display (e.g., "San Francisco, CA")
  neighborhood  String?  // Neighborhood/district (e.g., "Mission District")
  locationGranularity String @default("city") // "city" or "neighborhood"
  locationLat   Float?   // Latitude for radius search
  locationLng   Float?   // Longitude for radius search

  // ===== CAPABILITIES (Bot Readable) =====
  skills        String[] @default([]) // Tags for search
  equipment     String[] @default([]) // Hardware (car, drone, camera, etc.)
  languages     String[] @default([]) // ISO codes (en, es, zh, etc.)
  preferredLanguage String @default("en") // UI/email language preference
  isAvailable   Boolean  @default(true) // Open for work

  // ===== ECONOMICS (Deal Terms) =====
  minRateUsdc      Decimal? @db.Decimal(18, 6) // Minimum rate filter
  rateCurrency     String   @default("USD") // Currency for rate fields (USD, EUR, TRY, etc.)
  minRateUsdEstimate Decimal? @db.Decimal(18, 6) // Computed USD equivalent of minRateUsdc
  rateType         RateType @default(NEGOTIABLE)
  workMode         WorkMode?
  paymentPreferences String[] @default(["UPFRONT", "ESCROW", "UPON_COMPLETION"]) // Payment types accepted

  // ===== OFFER FILTERS (Anti-Spam) =====
  minOfferPrice    Decimal? @db.Decimal(18, 6) // Reject offers below this price
  maxOfferDistance Int?     // Reject offers from agents beyond this distance (km)

  // ===== COMMUNICATION =====
  contactEmail    String?
  telegram        String?
  telegramChatId  String?  // For sending notifications via bot
  whatsapp        String?  // WhatsApp number
  signal          String?  // Signal number

  // ===== PAYMENT METHODS =====
  paymentMethods  String?  // Free-text: PayPal, Venmo, Wise links, etc.

  // ===== PRIVACY =====
  hideContact     Boolean  @default(true) // Hide contact info from public profile

  // ===== EMAIL DIGEST =====
  emailDigestMode EmailDigestMode @default(REALTIME)

  // ===== ACTIVITY & REPUTATION (System Generated) =====
  lastActiveAt  DateTime @default(now()) // For deprioritizing ghosts
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // OAuth fields
  googleId          String?  @unique
  linkedinId        String?  @unique
  linkedinVerified  Boolean  @default(false)
  githubId          String?  @unique
  githubVerified    Boolean  @default(false)
  githubUsername     String?  // GitHub username for display

  // Referral tracking
  referralCode  String   @unique // Short code for referral links (auto-generated via middleware)
  referredBy    String?  // ID of the human who referred this user

  // Token invalidation for logout-all
  tokenInvalidatedAt DateTime? // All tokens issued before this time are invalid

  // Profile completion nudge tracking
  profileNudgeSentAt DateTime? // When last profile-completion reminder was sent

  // Privacy & legal compliance
  termsAcceptedAt        DateTime?
  emailVerified          Boolean    @default(false)
  emailVerificationToken String?    @unique
  emailNotifications     Boolean    @default(true)
  telegramNotifications  Boolean    @default(true)
  whatsappNotifications  Boolean    @default(true)
  analyticsOptOut        Boolean    @default(false) // GDPR: user can opt out of analytics tracking

  // Proof of humanity (Gitcoin Passport)
  humanityVerified       Boolean   @default(false)
  humanityProvider       String?                    // "gitcoin_passport"
  humanityScore          Float?                     // 0-100 score
  humanityVerifiedAt     DateTime?

  // Social profiles for trust verification
  linkedinUrl   String?
  twitterUrl    String?
  githubUrl     String?
  instagramUrl  String?
  youtubeUrl    String?
  websiteUrl    String?

  // Relations
  wallets       Wallet[]
  services      Service[]
  jobs          Job[]
  reviews       Review[]
  agentReports  AgentReport[]
  pendingNotifications PendingNotification[]
  vouchesGiven    Vouch[] @relation("VouchesGiven")
  vouchesReceived Vouch[] @relation("VouchesReceived")
  affiliate       Affiliate?
  affiliateReferral AffiliateReferral?
  feedback        Feedback[]

  // Indexes for fast agent search
  @@index([skills])
  @@index([locationLat, locationLng])
  @@index([neighborhood])
  @@index([isAvailable])
  @@index([lastActiveAt])
  @@index([isAvailable, lastActiveAt])
}

// Job status flow:
// One-time: PENDING -> ACCEPTED -> PAID -> COMPLETED
// Stream:   PENDING -> ACCEPTED -> STREAMING -> PAUSED -> COMPLETED
// Can be REJECTED or CANCELLED at various stages
enum JobStatus {
  PENDING    // Agent created offer, waiting for human to accept
  ACCEPTED   // Human accepted, waiting for payment
  REJECTED   // Human rejected the offer
  PAID       // Payment received, work can begin
  STREAMING  // Stream payment active (Superfluid flow or micro-transfers)
  PAUSED     // Stream paused (flow deleted or tick missed)
  COMPLETED  // Work done, review unlocked
  CANCELLED  // Cancelled by either party
  DISPUTED   // Payment dispute
}

model Agent {
  id                String    @id @default(cuid())
  name              String
  description       String?   @db.VarChar(500)
  websiteUrl        String?
  contactEmail      String?
  apiKeyHash        String                    // bcrypt hash of full API key
  apiKeyPrefix      String    @unique         // first 8 chars for lookup
  domainVerified    Boolean   @default(false)
  verificationToken String?                   // token for domain verification
  verifiedAt        DateTime?
  lastActiveAt      DateTime  @default(now())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // ===== ACTIVATION & GATING =====
  status              AgentStatus      @default(PENDING)
  activatedAt         DateTime?
  activationMethod    ActivationMethod?
  activationExpiresAt DateTime?
  activationTier      String           @default("BASIC") // BASIC, PRO, WHALE
  activationPlatform  String?          // "twitter", "linkedin", "github"
  socialVerificationCode String?
  socialCodeExpiresAt DateTime?
  socialPostUrl       String?          // URL of verification post
  socialAccountSize   Int?             // follower count at activation time
  paymentTxHash       String?          @unique // prevents reuse of same tx
  paymentNetwork      String?
  paymentAmount       Decimal?         @db.Decimal(18, 6)

  // ===== ERC-8004 REPUTATION REGISTRY =====
  erc8004AgentId  Int?  @unique  // Sequential ID for ERC-8004 registry. See docs/ERC-8004-MAPPING.md

  // ===== ABUSE TRACKING =====
  abuseScore   Int @default(0)
  abuseStrikes Int @default(0)

  // Relations
  jobs    Job[]
  reports AgentReport[]

  @@index([lastActiveAt])
  @@index([status])
}

model AgentReport {
  id              String       @id @default(cuid())
  agentId         String
  reporterHumanId String
  jobId           String?      // optional: the specific job that triggered the report
  reason          ReportReason
  description     String?      @db.VarChar(1000)
  status          ReportStatus @default(PENDING)
  createdAt       DateTime     @default(now())

  agent   Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  reporter Human @relation(fields: [reporterHumanId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([reporterHumanId])
  @@index([agentId, status])
}

model PendingNotification {
  id        String   @id @default(cuid())
  humanId   String
  type      String   // "job_offer" | "job_message"
  payload   Json
  createdAt DateTime @default(now())
  sentAt    DateTime?

  human Human @relation(fields: [humanId], references: [id], onDelete: Cascade)

  @@index([humanId, sentAt])
  @@index([sentAt, createdAt])
}

model Job {
  id              String    @id @default(cuid())
  humanId         String
  agentId         String    // Identifier for the AI agent/requester
  agentName       String?   // Display name for the agent

  // Registered agent (optional FK)
  registeredAgentId String?
  registeredAgent   Agent?  @relation(fields: [registeredAgentId], references: [id])

  // Job details
  title           String
  description     String
  category        String?

  // Agreed price (locked when human accepts)
  priceUsdc       Decimal   @db.Decimal(18, 6)

  // Payment details (filled when paid)
  paymentTxHash   String?   @unique // On-chain transaction hash (unique to prevent double-spend)
  paymentNetwork  String?   // e.g., "ethereum", "base", "polygon", "arbitrum"
  paymentAmount   Decimal?  @db.Decimal(18, 6) // Actual amount received
  paidAt          DateTime?
  paymentTiming   String?   @default("upfront") // "upfront" or "upon_completion"

  // ===== STREAM PAYMENT FIELDS =====
  paymentMode          PaymentMode    @default(ONE_TIME)
  streamMethod         StreamMethod?
  streamInterval       StreamInterval?
  streamRateUsdc       Decimal?       @db.Decimal(18, 6) // USD amount per interval
  streamFlowRate       String?        // Superfluid: wei/sec flow rate (stored as string because int96)
  streamMaxTicks       Int?           // Optional cap (null = indefinite)
  streamNetwork        String?        // Locked chain for all stream payments
  streamToken          String?        // Locked token (e.g. "USDC")
  streamSuperToken     String?        // Superfluid: Super Token contract address (e.g. USDCx)
  streamSenderAddress  String?        // Agent's wallet address (for flow verification)
  streamStartedAt      DateTime?      // When streaming began
  streamPausedAt       DateTime?      // When paused
  streamEndedAt        DateTime?      // When stopped
  streamTickCount      Int            @default(0) // Total verified ticks/checkpoints
  streamMissedTicks    Int            @default(0) // Consecutive misses (micro-transfer)
  streamTotalPaid      Decimal?       @db.Decimal(18, 6) // Running total paid
  streamGraceTicks     Int            @default(1) // Misses before auto-pause (micro-transfer)
  streamContractId     String?        // Future: Sablier stream ID

  // Webhook callback (optional, provided by agent)
  callbackUrl     String?   // URL to POST status updates to
  callbackSecret  String?   // HMAC-SHA256 secret for signing payloads

  status          JobStatus @default(PENDING)

  // Agent update tracking
  lastUpdatedByAgent DateTime?  // When the agent last updated the offer
  updateCount        Int        @default(0) // Number of times the offer was updated

  // Timestamps
  createdAt       DateTime  @default(now())
  acceptedAt      DateTime?
  completedAt     DateTime?
  updatedAt       DateTime  @updatedAt

  human           Human     @relation(fields: [humanId], references: [id], onDelete: Cascade)
  review          Review?
  messages        JobMessage[]
  streamTicks     StreamTick[]

  @@index([humanId, status])
  @@index([agentId])
  @@index([registeredAgentId])
  @@index([status])
  @@index([createdAt])
  @@index([humanId, status, createdAt])
  @@index([paymentMode, status])
  @@index([status, streamMethod])
}

model StreamTick {
  id              String     @id @default(cuid())
  jobId           String
  tickNumber      Int
  status          TickStatus @default(PENDING)
  expectedAt      DateTime
  graceDeadline   DateTime
  txHash          String?    @unique    // micro-transfer: on-chain txHash. superfluid: null
  network         String?
  token           String?
  amount          Decimal?   @db.Decimal(18, 6)
  fromAddress     String?
  toAddress       String?
  verifiedAt      DateTime?
  confirmations   Int?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  job             Job        @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, tickNumber])
  @@index([jobId, status])
  @@index([status, graceDeadline])
}

// ERC-8004: The fields below (erc8004*) store pre-computed values for the
// ERC-8004 Reputation Registry's `giveFeedback(agentId, value, valueDecimals,
// tag1, tag2, feedbackHash)` call. They are derived from `rating` and job
// metadata at review-creation time. A future on-chain bridge can publish them
// directly without re-deriving anything.
//
// Invariants — DO NOT break:
//   • erc8004Value == rating * 20   (1★=20 … 5★=100)
//   • erc8004ValueDecimals == 0     (integer percent scale)
//   • erc8004Tag1 == "starred"      (constant for star ratings)
//   • erc8004FeedbackHash == SHA-256 of canonical feedback JSON (sorted keys)
//
// See docs/ERC-8004-MAPPING.md for the full specification.
model Review {
  id          String   @id @default(cuid())
  jobId       String   @unique
  humanId     String

  rating      Int      // 1-5 stars
  comment     String?

  // ERC-8004 pre-computed fields (see block comment above)
  erc8004Value         Int?     // Math.round((rating / 5) * 100). 1★=20, 5★=100
  erc8004ValueDecimals Int      @default(0)
  erc8004Tag1          String   @default("starred")
  erc8004Tag2          String   @default("")        // from Job.category
  erc8004FeedbackHash  String?                      // SHA-256 of canonical feedback JSON

  createdAt   DateTime @default(now())

  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  human       Human    @relation(fields: [humanId], references: [id], onDelete: Cascade)

  @@index([humanId])
  @@index([createdAt])
}

model Wallet {
  id        String   @id @default(cuid())
  humanId   String
  network   String   // e.g., "ethereum", "base", "solana", "bitcoin"
  chain     String?  // Specific chain: "BASE", "OPTIMISM", "ARBITRUM", etc.
  address   String
  label     String?  // e.g., "Main wallet", "Business"
  isPrimary Boolean  @default(false) // Preferred payment wallet
  createdAt DateTime @default(now())

  human     Human    @relation(fields: [humanId], references: [id], onDelete: Cascade)

  @@unique([humanId, network, address])
  @@index([humanId, isPrimary])
  @@index([address])
}

model Service {
  id              String    @id @default(cuid())
  humanId         String
  title           String
  description     String
  category        String
  priceMin        Decimal?  @db.Decimal(10, 2)
  priceCurrency   String    @default("USD") // Currency for service price
  priceUnit       RateType?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  human           Human     @relation(fields: [humanId], references: [id], onDelete: Cascade)

  @@index([humanId])
  @@index([category])
}

model JobMessage {
  id         String   @id @default(cuid())
  jobId      String
  senderType String   // "human" or "agent"
  senderId   String   // human.id or agent.id
  senderName String   // snapshot at write time
  content    String   @db.VarChar(2000)
  createdAt  DateTime @default(now())
  job        Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
}

model OAuthState {
  token     String   @id
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email])
}

model Vouch {
  id          String   @id @default(cuid())
  voucherId   String
  voucheeId   String
  comment     String?  @db.VarChar(200)
  createdAt   DateTime @default(now())

  voucher     Human @relation("VouchesGiven", fields: [voucherId], references: [id], onDelete: Cascade)
  vouchee     Human @relation("VouchesReceived", fields: [voucheeId], references: [id], onDelete: Cascade)

  @@unique([voucherId, voucheeId])
  @@index([voucheeId])
}

// ===== REFERRAL PROGRAM =====
// Single-tier referral credits. Every user is automatically a referrer. No MLM.

enum AffiliateStatus {
  APPROVED   // Active referrer
  SUSPENDED  // Temporarily disabled (fraud, TOS violation)
}

model Affiliate {
  id              String          @id @default(cuid())
  humanId         String          @unique  // One referrer record per human
  status          AffiliateStatus @default(APPROVED)

  // Credits config (per-user overrides; defaults in app config)
  creditsPerReferral Int          @default(10)   // Credits earned per qualified signup
  bonusTier1      Int             @default(50)   // Bonus credits at 10 referrals
  bonusTier2      Int             @default(200)  // Bonus credits at 50 referrals
  bonusTier3      Int             @default(500)  // Bonus credits at 100 referrals

  // Stats (denormalized for fast reads)
  totalSignups    Int             @default(0)
  qualifiedSignups Int            @default(0) // Signups that completed profile
  totalCredits    Int             @default(0) // Total credits earned
  creditsRedeemed Int             @default(0) // Credits already redeemed

  // Admin
  suspendedAt     DateTime?
  suspendedReason String?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relations
  human           Human           @relation(fields: [humanId], references: [id], onDelete: Cascade)
  referrals       AffiliateReferral[]
  creditLedger    AffiliateCredit[]

  @@index([status])
}

model AffiliateReferral {
  id              String    @id @default(cuid())
  affiliateId     String
  referredHumanId String    @unique // Each human can only be referred once
  qualified       Boolean   @default(false) // True when profile is completed
  qualifiedAt     DateTime?

  // Fraud detection
  ipAddress       String?
  userAgent       String?

  // Credits
  creditsAwarded  Int      @default(0) // Credits earned for this referral
  creditsClaimed  Boolean  @default(false)

  createdAt       DateTime  @default(now())

  affiliate       Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  referredHuman   Human     @relation(fields: [referredHumanId], references: [id], onDelete: Cascade)

  @@index([affiliateId, qualified])
  @@index([affiliateId, createdAt])
}

model AffiliateCredit {
  id              String   @id @default(cuid())
  affiliateId     String
  credits         Int      // Number of credits
  type            String   @default("referral") // "referral" | "bonus_tier1" | "bonus_tier2" | "bonus_tier3"
  description     String?

  createdAt       DateTime @default(now())

  affiliate       Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@index([affiliateId])
  @@index([affiliateId, type])
}

// ===== USER FEEDBACK & BUG REPORTS =====

enum FeedbackType {
  BUG
  FEATURE
  FEEDBACK
}

enum FeedbackStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model Feedback {
  id              String         @id @default(cuid())
  humanId         String?        // Nullable: allow anonymous feedback
  type            FeedbackType   @default(FEEDBACK)
  category        String?        // "ui", "performance", "payments", "jobs", "search", "other"
  title           String?        @db.VarChar(200)
  description     String         @db.VarChar(5000)
  sentiment       Int?           // 1-5 emoji scale

  // Bug-report fields
  stepsToReproduce  String?      @db.VarChar(2000)
  expectedBehavior  String?      @db.VarChar(1000)
  actualBehavior    String?      @db.VarChar(1000)
  severity          String?      // "low" | "medium" | "high" | "critical"

  // Auto-captured context
  pageUrl         String?
  browser         String?
  os              String?
  viewport        String?        // "1920x1080"
  userAgent       String?
  appVersion      String?
  screenshotData  String?        @db.Text // base64 data URI

  // Admin processing
  status          FeedbackStatus @default(NEW)
  adminNotes      String?        @db.VarChar(2000)

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  human           Human?         @relation(fields: [humanId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([humanId])
}
