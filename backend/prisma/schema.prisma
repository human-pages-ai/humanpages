  updatedAt    DateTime         @updatedAt

  human      Human  @relation(fields: [humanId], references: [id], onDelete: Cascade)
  reviewedBy Human? @relation("AdjustmentReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

